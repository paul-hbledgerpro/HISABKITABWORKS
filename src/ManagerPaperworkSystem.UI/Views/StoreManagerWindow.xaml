<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.StoreManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Store Manager — Hisab Kitab" Height="520" Width="900" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI">

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- HEADER -->
    <Border Grid.Row="0" Background="#FF111118" BorderBrush="#FFD4AF37" BorderThickness="0,0,0,2" CornerRadius="8,8,0,0" Padding="16,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="🏪" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <StackPanel>
            <TextBlock Text="STORE MANAGER" FontSize="18" FontWeight="ExtraBold" Foreground="#FFD4AF37"/>
            <TextBlock Text="Manage your stores — add, edit, or remove" FontSize="11" Foreground="#FF8a8a9a" Margin="0,2,0,0"/>
          </StackPanel>
        </StackPanel>
        <Button x:Name="btnAddNew" Content="➕ Add New Store" HorizontalAlignment="Right" VerticalAlignment="Center"
                Width="170" Height="36" Click="AddNewStore_Click" FontWeight="Bold" FontSize="13"/>
      </Grid>
    </Border>

    <!-- STORES GRID -->
    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="2">
      <DataGrid x:Name="gridStores" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="#FF222230" RowHeight="38">
        <DataGrid.Columns>
          <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
          <DataGridTextColumn Header="Store Name" Binding="{Binding Name}" Width="*"/>
          <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
          <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
          <DataGridTextColumn Header="Created" Binding="{Binding CreatedUtc, StringFormat='{}{0:MM/dd/yyyy}'}" Width="110" IsReadOnly="True"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- FOOTER -->
    <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="lblStatus" VerticalAlignment="Center" Foreground="#FF8a8a9a" FontSize="12"/>
        <Button Grid.Column="1" Content="⭐ Set Default" Width="120" Margin="0,0,8,0" Click="SetDefault_Click" FontWeight="SemiBold"/>
        <Button Grid.Column="2" Content="🗑 Delete Store" Width="130" Margin="0,0,8,0" Click="DeleteStore_Click" FontWeight="SemiBold" Foreground="#FFef4444"/>
        <Button Grid.Column="3" Content="💾 Save Changes" Width="130" Margin="0,0,8,0" Click="Save_Click" FontWeight="SemiBold"/>
        <Button Grid.Column="4" Content="Close" Width="90" Click="Close_Click"/>
      </Grid>
    </Border>
  </Grid>
</Window>
