<Window x:Class="ManagerPaperworkSystem.UI.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HISAB KITAB - Software Update" 
        Width="580" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#FF0B0B0F"
        Foreground="White"
        ResizeMode="NoResize">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Software Update" FontSize="24" FontWeight="Bold" Foreground="#FFD4AF37"/>
      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
        <TextBlock Text="Current Version: " Foreground="#AAAAAA"/>
        <TextBlock x:Name="txtCurrentVersion" Text="1.0.0" Foreground="White" FontWeight="SemiBold"/>
      </StackPanel>
    </StackPanel>

    <!-- Master Password Entry -->
    <Border x:Name="pnlPassword" Grid.Row="1" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="Enter Master Password" FontWeight="SemiBold" Foreground="#FFD4AF37" Margin="0,0,0,8"/>
        <TextBlock Text="This feature is for authorized programmers only." Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,10"/>
        <PasswordBox x:Name="txtPassword" Height="35" FontSize="14" Margin="0,0,0,10"
                     Background="#FFFFFFFF" Foreground="#FF000000" BorderBrush="#FFD4AF37" Padding="8,4"/>
        <Button x:Name="btnVerify" Content="Verify Password" Height="38"
                Click="BtnVerify_Click" Style="{StaticResource PrimaryButton}"/>
        <TextBlock x:Name="txtPasswordError" Text="" Foreground="#FFFF6B6B" Margin="0,8,0,0" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <!-- UPDATE OPTIONS (shown after password verified) -->
    <Border x:Name="pnlUpdateOptions" Grid.Row="2" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,12" Visibility="Collapsed">
      <StackPanel>
        <TextBlock Text="UPDATE FROM LOCAL FILE" FontWeight="Bold" Foreground="#FFD4AF37" FontSize="13" Margin="0,0,0,8"/>
        <TextBlock Text="Browse for an update package (.zip or .mpsupdate) from your computer or network drive." 
                   Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
        
        <!-- File Browse Row -->
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="txtFilePath" Grid.Column="0" Height="35" IsReadOnly="True" FontSize="12"
                   Background="#FF2A2A35" Foreground="White" BorderBrush="#FF555555" Padding="8,6"
                   Text="No file selected..."/>
          <Button x:Name="btnBrowse" Grid.Column="1" Content="Browse..." Width="90" Height="35" Margin="8,0,0,0"
                  Click="BtnBrowse_Click" Style="{StaticResource SecondaryButton}"/>
        </Grid>
        
        <Button x:Name="btnApplyLocal" Content="Apply Update" Height="40"
                Click="BtnApplyLocal_Click" Style="{StaticResource PrimaryButton}" IsEnabled="False"/>
        
        <!-- Separator -->
        <Border Height="1" Background="#FF333340" Margin="0,16,0,12"/>
        
        <!-- Server Check (secondary) -->
        <TextBlock Text="CHECK SERVER FOR UPDATES" FontWeight="Bold" Foreground="#FFD4AF37" FontSize="13" Margin="0,0,0,8"/>
        <Button x:Name="btnCheckServer" Content="Check for Updates Online" Height="36"
                Click="BtnCheckServer_Click" Style="{StaticResource SecondaryButton}"/>
                
        <!-- Server update available panel -->
        <StackPanel x:Name="pnlServerUpdate" Visibility="Collapsed" Margin="0,10,0,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="New Version: " Foreground="#AAAAAA"/>
            <TextBlock x:Name="txtNewVersion" Foreground="#4ADE80" FontWeight="Bold"/>
          </StackPanel>
          <TextBlock x:Name="txtReleaseNotes" Foreground="White" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <Button x:Name="btnDownloadServer" Content="Download &amp; Install" Height="36" Margin="0,10,0,0"
                  Click="BtnDownloadServer_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Progress Panel -->
    <Border x:Name="pnlProgress" Grid.Row="3" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,12" Visibility="Collapsed">
      <StackPanel>
        <TextBlock x:Name="txtProgressLabel" Text="Applying update..." Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ProgressBar x:Name="progressBar" Height="22" Minimum="0" Maximum="100" 
                     Foreground="#FFD4AF37" Background="#FF2A2A35"/>
        <TextBlock x:Name="txtProgress" Text="0%" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
      </StackPanel>
    </Border>

    <!-- Rollback Panel -->
    <Border x:Name="pnlRollback" Grid.Row="4" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,12" Visibility="Collapsed">
      <StackPanel>
        <TextBlock Text="ROLLBACK" FontWeight="Bold" Foreground="#FFFF6B6B" FontSize="13" Margin="0,0,0,8"/>
        <TextBlock Text="If the last update caused issues, you can roll back to the previous version." 
                   Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <Button x:Name="btnRollback" Content="Rollback Last Update" Height="36"
                Click="BtnRollback_Click" Style="{StaticResource SecondaryButton}"/>
      </StackPanel>
    </Border>

    <!-- Status Messages -->
    <TextBlock Grid.Row="5" x:Name="txtStatus" Text="" Foreground="#AAAAAA" TextWrapping="Wrap" VerticalAlignment="Top"/>

    <!-- Close Button -->
    <Button Grid.Row="6" x:Name="btnClose" Content="Close" Width="100" Height="35" 
            HorizontalAlignment="Right" Click="BtnClose_Click" Style="{StaticResource SecondaryButton}"/>
  </Grid>
</Window>
