<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.CashCorrectionWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:ManagerPaperworkSystem.UI.Controls" Title="HISAB KITAB - Cash Correction" Height="640" Width="640" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI"> <Grid Margin="20"> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions> <TextBlock Grid.Row="0" Text="Add a correction (does not change the original record)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/> <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12"> <StackPanel> <TextBlock Text="Original Record" FontWeight="SemiBold" Margin="0,0,0,6"/> <TextBlock x:Name="txtOriginal" TextWrapping="Wrap" Opacity="0.9"/> </StackPanel> </Border> <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"> <StackPanel> <TextBlock Text="Corrected Values" FontWeight="SemiBold" Margin="0,0,0,8"/> <Grid> <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="12"/> <ColumnDefinition Width="*"/> </Grid.ColumnDefinitions> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions> <StackPanel Grid.Row="0" Grid.Column="0"> <TextBlock Text="Date"/> <controls:WinDatePicker x:Name="dpDate"/> </StackPanel> <StackPanel Grid.Row="0" Grid.Column="2"> <TextBlock Text="Is Payout"/> <ComboBox x:Name="cmbIsPayout"/> </StackPanel> <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0"> <TextBlock Text="Cash Added"/> <TextBox x:Name="txtCashAdded"/> </StackPanel> <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0"> <TextBlock Text="Payout Amount"/> <TextBox x:Name="txtPayoutAmount"/> </StackPanel> <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,10,0,0"> <TextBlock Text="Vendor"/> <ComboBox x:Name="cmbVendor"/> </StackPanel> <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,10,0,0"> <TextBlock Text="Purpose"/> <ComboBox x:Name="cmbPurpose"/> </StackPanel> <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0"> <TextBlock Text="Description"/> <TextBox x:Name="txtDesc"/> </StackPanel> </Grid> <TextBlock Text="Reason" Margin="0,14,0,0"/> <TextBox x:Name="txtReason" AcceptsReturn="True" Height="80" TextWrapping="Wrap"/> <TextBlock x:Name="lblError" Foreground="#FFFF6B6B" TextWrapping="Wrap" Margin="0,12,0,0"/> </StackPanel> </ScrollViewer> <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"> <Button Content="Cancel" Width="110" Margin="0,0,10,0" Click="Cancel_Click"/> <Button Content="Save Correction" Width="140" Click="Save_Click"/> </StackPanel> </Grid>
</Window>
