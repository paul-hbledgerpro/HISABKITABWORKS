<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.PdfPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="HISAB KITAB - Print Preview" Height="720" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" Content="◀" Width="44" Margin="0,0,8,0" Click="Prev_Click"/>
      <Button Grid.Column="1" Content="▶" Width="44" Margin="0,0,12,0" Click="Next_Click"/>

      <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="Preview:"/>
      <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" x:Name="txtFile"/>

      <Button Grid.Column="4" Content="Print..." Margin="0,0,8,0" Click="Print_Click"/>
      <Button Grid.Column="5" Content="Open" Click="Open_Click"/>
    </Grid>

    <!-- PDF preview surface -->
    <Border Grid.Row="1" CornerRadius="10" BorderBrush="#2A2A2A" BorderThickness="1" Background="#0C0F16">
      <wv2:WebView2 x:Name="web"/>
    </Border>

    <!-- Bottom help/status -->
    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0" Opacity="0.75" TextWrapping="Wrap"
                 Text="Tip: Use Print... to choose printer and settings. If preview is blank the first time, wait a second for the PDF to load."/>
      <Button Grid.Column="1" Content="Close" Margin="12,0,0,0" Click="Close_Click"/>
    </Grid>
  </Grid>
</Window>
