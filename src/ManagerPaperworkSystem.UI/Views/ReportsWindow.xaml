<Window x:Class="ManagerPaperworkSystem.UI.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ManagerPaperworkSystem.UI.Converters"
        Title="HISAB KITAB - Reports"
        Icon="pack://application:,,,/Assets/HisabKitab.ico"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF081A2A"
        Foreground="#FFF4F1EA"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <conv:EnumDisplayConverter x:Key="EnumDisplayConverter"/>
        <SolidColorBrush x:Key="ReportPanelBrush" Color="#FF10243A"/>
        <SolidColorBrush x:Key="ReportControlBrush" Color="#FF0E263D"/>
        <SolidColorBrush x:Key="ReportBorderBrush" Color="#FFB87333"/>
        <SolidColorBrush x:Key="ReportTextBrush" Color="#FFF4F1EA"/>
        <SolidColorBrush x:Key="ReportMutedBrush" Color="#FF9BA8B5"/>
        <SolidColorBrush x:Key="ReportCopperBrush" Color="#FFD49A5B"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ReportControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ReportTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ReportBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ReportControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ReportTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ReportBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ReportControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ReportCopperBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ReportBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="FilledReportButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ReportCopperBrush}"/>
            <Setter Property="Foreground" Value="#FF0C1118"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE8A5;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="42"
                       Foreground="{StaticResource ReportCopperBrush}"
                       Margin="0,0,18,0"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Reports"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#FFF1C18C"/>
                <TextBlock Text="Generate, print, and review store reports."
                           FontSize="13"
                           Foreground="{StaticResource ReportMutedBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="2"
                    Content="Close"
                    Width="120"
                    Click="Close_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource ReportPanelBrush}"
                    BorderBrush="{StaticResource ReportBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width=".9*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="4"
                               Text="Generate Report"
                               Foreground="{StaticResource ReportCopperBrush}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,14,10">
                        <TextBlock Text="Report Type" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbReportType">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}"
                                               Foreground="#FF0C1118"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,14,10">
                        <TextBlock Text="From" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpFrom" Style="{StaticResource GoldDatePicker}" Height="38"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,14,10">
                        <TextBlock Text="To" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpTo" Style="{StaticResource GoldDatePicker}" Height="38"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,10">
                        <TextBlock Text="Format" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Border Background="{StaticResource ReportControlBrush}"
                                BorderBrush="{StaticResource ReportBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Height="38">
                            <TextBlock Text="PDF"
                                       Foreground="{StaticResource ReportCopperBrush}"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.ColumnSpan="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0">
                        <Button Content="Print"
                                Width="150"
                                Margin="0,0,12,0"
                                Click="Print_Click"/>
                        <Button Content="Generate PDF"
                                Width="180"
                                Style="{StaticResource FilledReportButton}"
                                Click="Generate_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource ReportPanelBrush}"
                    BorderBrush="{StaticResource ReportBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Quick Report Types"
                               Foreground="{StaticResource ReportCopperBrush}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Sales Summary by Date"
                               Foreground="{StaticResource ReportTextBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Shift Log"
                               Foreground="{StaticResource ReportTextBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Cash On Hand"
                               Foreground="{StaticResource ReportTextBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Check Payouts"
                               Foreground="{StaticResource ReportTextBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="All Reports"
                               Foreground="{StaticResource ReportTextBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource ReportPanelBrush}"
                BorderBrush="{StaticResource ReportBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Report Preview"
                           Foreground="{StaticResource ReportCopperBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>
                <Border Grid.Row="1"
                        Background="#FF0E263D"
                        BorderBrush="#FF24445F"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Generated reports open in the PDF preview window."
                                   Foreground="{StaticResource ReportTextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="This area stays blank until report history storage is added."
                                   Foreground="{StaticResource ReportMutedBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="lblError"
                   Foreground="#FFFF6B6B"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>
