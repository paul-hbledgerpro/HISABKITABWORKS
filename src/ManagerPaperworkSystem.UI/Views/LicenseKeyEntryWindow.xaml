<Window x:Class="ManagerPaperworkSystem.UI.Views.LicenseKeyEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hisab Kitab — License Activation"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B0B0F">

    <Window.Resources>
        <SolidColorBrush x:Key="Gold" Color="#D4AF37"/>
        <SolidColorBrush x:Key="GoldDim" Color="#40D4AF37"/>
        <SolidColorBrush x:Key="CardBg" Color="#13131A"/>
        <SolidColorBrush x:Key="BorderBr" Color="#222230"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0ECE0"/>
        <SolidColorBrush x:Key="TextDim" Color="#8A8A9A"/>
        <SolidColorBrush x:Key="ErrorRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22C55E"/>
    </Window.Resources>

    <Grid>
        <StackPanel Margin="40,30" VerticalAlignment="Center">

            <!-- Logo / Header -->
            <TextBlock Text="🔑" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="HISAB KITAB" FontSize="22" FontWeight="Black" Foreground="{StaticResource Gold}"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="SOFTWARE UPDATE — LICENSE REQUIRED" FontSize="11" Foreground="{StaticResource TextDim}"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <TextBlock Text="Your software has been updated. Please enter your license key to continue."
                       Foreground="{StaticResource TextDim}" FontSize="13" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>

            <!-- License Key Input -->
            <TextBlock Text="LICENSE KEY" Foreground="{StaticResource Gold}" FontSize="11" FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtLicenseKey"
                     FontSize="18" FontFamily="Consolas" FontWeight="Bold"
                     Padding="12,10" MaxLength="18"
                     CharacterCasing="Upper"
                     Background="#0B0B0F" Foreground="#F0ECE0"
                     BorderBrush="{StaticResource BorderBr}" BorderThickness="1"
                     CaretBrush="{StaticResource Gold}"/>
            <TextBlock Text="Format: HBL-XXXX-XXXX-XXXX" Foreground="{StaticResource TextDim}" FontSize="11"
                       Margin="0,4,0,16"/>

            <!-- Status Message -->
            <TextBlock x:Name="txtStatus" Text="" FontSize="13" TextWrapping="Wrap"
                       Foreground="{StaticResource ErrorRed}" Margin="0,0,0,16"
                       HorizontalAlignment="Center" TextAlignment="Center"/>

            <!-- Activate Button -->
            <Button x:Name="btnActivate" Content="✓  ACTIVATE LICENSE" Click="Activate_Click"
                    FontSize="15" FontWeight="Bold" Padding="16,12" Cursor="Hand"
                    HorizontalAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource Gold}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5C040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="#000000"/>
                </Button.Foreground>
            </Button>

            <!-- Cancel -->
            <Button Content="Exit Application" Click="Cancel_Click"
                    Background="Transparent" Foreground="{StaticResource TextDim}"
                    FontSize="12" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Center" Padding="12,6" Margin="0,12,0,0"/>

        </StackPanel>
    </Grid>
</Window>
