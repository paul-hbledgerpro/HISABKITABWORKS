<Window x:Class="ManagerPaperworkSystem.UI.Views.DatabaseSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Connection Settings" 
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="pack://application:,,,/Assets/HisabKitab.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Database Connection" FontSize="22" FontWeight="Bold" 
                       Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="txtCurrentConnection" Text="Loading..." 
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Connection Info -->
        <Border Grid.Row="1" Background="#FF1A1A22" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Server Address:" Foreground="{StaticResource AccentBrush}" 
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="txtServer" Height="40" FontSize="14" 
                         Background="#FFFFFFFF" Foreground="#FF000000" 
                         BorderBrush="{StaticResource AccentBrush}" Padding="10,8"/>
                <TextBlock Text="Enter the server IP or hostname (e.g., 10.1.10.233 or .\SQLEXPRESS)" 
                           Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,6,0,0"/>
                
                <!-- Test Button and Status -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Test Connection" Height="36" Width="140" Click="TestConnection_Click"
                            Background="{StaticResource AccentBrush}" Foreground="#FF000000" 
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    <TextBlock x:Name="txtConnectionStatus" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Info Notice -->
        <Border Grid.Row="2" Background="#FF252530" CornerRadius="6" Padding="12">
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="11">
                <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">Note:</Run>
                <Run Text=" Database credentials are configured by your administrator during initial setup. Contact your administrator if you need to change the database connection."/>
            </TextBlock>
        </Border>

        <!-- Error Message -->
        <TextBlock Grid.Row="3" x:Name="txtError" Foreground="#FFFF6B6B" TextWrapping="Wrap" 
                   VerticalAlignment="Bottom" Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="100" Height="38" Margin="0,0,10,0" 
                    Background="Transparent" Foreground="{StaticResource AccentBrush}" 
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
                    FontWeight="SemiBold" Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="Save &amp; Restart" Width="130" Height="38" 
                    Background="{StaticResource AccentBrush}" Foreground="#FF000000" 
                    FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
