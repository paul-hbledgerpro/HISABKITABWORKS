<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.UserAccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HISAB KITAB - User Accounts" Height="520" Width="820" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI">

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="User Accounts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

    <DataGrid Grid.Row="1" x:Name="gridUsers" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="140"/>
        <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="180"/>
        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
        <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
        <DataGridTextColumn Header="Last Login" Binding="{Binding LastLoginUtc}" Width="140"/>
      </DataGrid.Columns>
    </DataGrid>

    <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
      <TextBlock x:Name="lblError" Foreground="#FFFF6B6B" TextWrapping="Wrap" DockPanel.Dock="Left"/>
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
        <Button Content="New Account..." Width="140" Margin="0,0,10,0" Click="New_Click"/>
        <Button Content="Enable/Disable" Width="140" Margin="0,0,10,0" Click="ToggleActive_Click"/>
        <Button Content="Close" Width="110" Click="Close_Click"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
