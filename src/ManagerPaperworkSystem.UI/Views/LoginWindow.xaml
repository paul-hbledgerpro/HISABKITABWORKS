<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HISAB KITAB - Sign in" 
        Height="480" Width="750" 
        MinHeight="480" MinWidth="750"
        MaxHeight="480" MaxWidth="750"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" 
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

  <Window.Resources>
    <!-- Animated Gold Button Style -->
    <Style x:Key="AnimatedGoldButton" TargetType="Button">
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="MinWidth" Value="130"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <!-- Shadow layer -->
              <Border x:Name="Shadow" CornerRadius="14" Background="#1A000000" Margin="0,3,0,0" Opacity="0.22"/>
              
              <!-- Main button -->
              <Border x:Name="Bd" CornerRadius="14" BorderThickness="1" BorderBrush="#FFD4AF37">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFF5D6" Offset="0"/>
                    <GradientStop Color="#FFE8C872" Offset="0.55"/>
                    <GradientStop Color="#FFD4AF37" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <TranslateTransform x:Name="BdTransform" Y="0"/>
                </Border.RenderTransform>
                <Border.Effect>
                  <DropShadowEffect x:Name="BdShadow" BlurRadius="18" ShadowDepth="4" Opacity="0.16" Color="#FFD4AF37"/>
                </Border.Effect>
                
                <Grid>
                  <!-- Gloss highlight -->
                  <Border x:Name="Gloss" CornerRadius="14" Margin="1" Opacity="0.28" IsHitTestVisible="False">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                        <GradientStop Color="#55FFFFFF" Offset="0.28"/>
                        <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>
                  
                  <!-- Shimmer effect -->
                  <Rectangle x:Name="ShimmerX" IsHitTestVisible="False" Opacity="0" RadiusX="14" RadiusY="14">
                    <Rectangle.Fill>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                        <GradientStop Color="#44FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                      </LinearGradientBrush>
                    </Rectangle.Fill>
                  </Rectangle>
                  
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                    <ContentPresenter.Resources>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FF000000"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                      </Style>
                    </ContentPresenter.Resources>
                  </ContentPresenter>
                </Grid>
              </Border>
            </Grid>
            
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFFFFFFF" Offset="0"/>
                      <GradientStop Color="#FFFFE9B0" Offset="0.55"/>
                      <GradientStop Color="#FFF1D27A" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
                <Setter TargetName="Shadow" Property="Opacity" Value="0.26"/>
                <Setter TargetName="ShimmerX" Property="Opacity" Value="0.4"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFB68B1E" Offset="0"/>
                      <GradientStop Color="#FF9A7014" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
                <Setter TargetName="Shadow" Property="Margin" Value="0,1,0,0"/>
                <Setter TargetName="Gloss" Property="Opacity" Value="0.18"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    
    <!-- Store Selection Button Style -->
    <Style x:Key="StoreSelectButton" TargetType="Button">
      <Setter Property="MinHeight" Value="52"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource AccentBrush}" 
                    Background="#FF1A1A1A" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#FF2A2A1A"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFF1D27A"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#FF3A3A2A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Hyperlink Button Style -->
    <Style x:Key="HyperlinkButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <TextBlock x:Name="LinkText"
                       Text="{TemplateBinding Content}"
                       Foreground="{TemplateBinding Foreground}"
                       FontSize="{TemplateBinding FontSize}"
                       TextDecorations="Underline"
                       Cursor="Hand"/>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="LinkText" Property="Foreground" Value="#FFF1D27A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="55"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="25"/>
    </Grid.RowDefinitions>

    <!-- Header Bar -->
    <Border Grid.Row="0" Background="{StaticResource AccentGradient}">
      <Grid Margin="20,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Image Source="pack://application:,,,/Assets/HisabKitab_Logo.png"
                 Height="38" Width="95" Stretch="Uniform" Margin="0,0,12,0"/>
          <TextBlock Text="HISAB KITAB" 
                     FontSize="20" 
                     FontWeight="Bold" 
                     Foreground="White"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="380"/>
      </Grid.ColumnDefinitions>

      <!-- Left Panel - Branding -->
      <Border Grid.Column="0" Background="{StaticResource BgBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <Image Source="pack://application:,,,/Assets/HisabKitab_Logo.png"
                 Height="180" Width="280" 
                 Stretch="Uniform" 
                 Opacity="1"
                 Margin="0,0,0,15"/>
          <TextBlock Text="Professional Store Management" 
                     FontSize="14" 
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,6"/>
          <TextBlock Text="Secure • Reliable • Efficient" 
                     FontSize="11" 
                     Foreground="{StaticResource MutedTextBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Right Panel - Login Form -->
      <Border Grid.Column="1" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="24,16,24,16">
        <Grid>
          <!-- ═══ STEP 1: Credentials Panel ═══ -->
          <StackPanel x:Name="panelCredentials" Visibility="Visible">
            <TextBlock Text="Sign In" 
                       FontSize="18" 
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,8,0,20"/>

            <TextBlock Text="User ID :" 
                       FontSize="12" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBox x:Name="txtUser"
                     Height="36"
                     FontSize="13"
                     Padding="10,6"
                     Margin="0,4,0,12"
                     Background="#FFFFFFFF"
                     Foreground="#FF000000"
                     BorderThickness="1"
                     BorderBrush="{StaticResource AccentBrush}"
                     KeyDown="User_KeyDown"/>

            <TextBlock Text="Password :" 
                       FontSize="12" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"/>
            <PasswordBox x:Name="pwd"
                         Height="36"
                         FontSize="13"
                         Padding="10,6"
                         Margin="0,4,0,12"
                         Background="#FFFFFFFF"
                         Foreground="#FF000000"
                         BorderThickness="1"
                         BorderBrush="{StaticResource AccentBrush}"
                         KeyDown="Pwd_KeyDown"/>

            <TextBlock x:Name="lblError" 
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <UniformGrid Columns="2" Rows="1" Margin="0,4,0,0">
              <Button Content="SIGN IN" 
                      Style="{StaticResource AnimatedGoldButton}"
                      Margin="0,0,8,0"
                      Click="Login_Click"
                      IsDefault="True"/>
              <Button Content="CANCEL" 
                      Style="{StaticResource AnimatedGoldButton}"
                      Margin="8,0,0,0"
                      Click="Exit_Click"
                      IsCancel="True"/>
            </UniformGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
              <Button Content="CREATE ACCOUNT" 
                      Style="{StaticResource HyperlinkButton}"
                      Click="CreateAccount_Click"/>
              <TextBlock Text=" | " 
                         FontSize="11" 
                         Foreground="{StaticResource AccentBrush}"
                         VerticalAlignment="Center"
                         Margin="10,0"/>
              <Button Content="FORGOT PASSWORD" 
                      Style="{StaticResource HyperlinkButton}"
                      Click="ForgotPassword_Click"/>
            </StackPanel>
          </StackPanel>

          <!-- ═══ STEP 2: Store Selection Popup Overlay ═══ -->
          <Border x:Name="panelStoreSelect" Visibility="Collapsed"
                  Background="#F0111111" CornerRadius="12" 
                  BorderBrush="{StaticResource AccentBrush}" BorderThickness="2"
                  Padding="20" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <StackPanel>
              <TextBlock x:Name="lblWelcome"
                         FontSize="16" 
                         FontWeight="Bold"
                         Foreground="{StaticResource AccentBrush}"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,4"/>
              
              <TextBlock Text="Select a store to continue" 
                         FontSize="12" 
                         Foreground="{StaticResource MutedTextBrush}"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,16"/>

              <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto" 
                            HorizontalScrollBarVisibility="Disabled"
                            Padding="0,0,4,0">
              <ItemsControl x:Name="storeList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Style="{StaticResource StoreSelectButton}"
                            Margin="0,0,0,8"
                            Click="StoreSelect_Click"
                            Tag="{Binding}">
                      <StackPanel>
                        <TextBlock Text="{Binding StoreName}" 
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding StoreAddress}" 
                                   FontSize="10" 
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,2,0,0"/>
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              </ScrollViewer>

              <TextBlock x:Name="lblStoreError" 
                         Foreground="{StaticResource ErrorBrush}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0"/>

              <Button Content="← BACK" 
                      Style="{StaticResource HyperlinkButton}"
                      FontSize="12"
                      HorizontalAlignment="Center"
                      Margin="0,12,0,0"
                      Click="BackToLogin_Click"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- Footer -->
    <TextBlock Grid.Row="2"
               Text="Copyright©2026, Hisab Kitab. All rights reserved."
               FontSize="9"
               Foreground="{StaticResource MutedTextBrush}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
  </Grid>
</Window>
