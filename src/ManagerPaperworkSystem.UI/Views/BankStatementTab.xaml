<UserControl x:Class="ManagerPaperworkSystem.UI.Views.BankStatementTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF0B0B0F">
    <UserControl.Resources>
        <!-- P&L Category list for the ComboBox -->
        <x:Array x:Key="PLCategories" Type="{x:Type sys:String}"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <sys:String>Utilities</sys:String>
            <sys:String>Rent</sys:String>
            <sys:String>Payroll</sys:String>
            <sys:String>Insurance</sys:String>
            <sys:String>Inventory/COGS</sys:String>
            <sys:String>Bank Fees</sys:String>
            <sys:String>Tax Payment</sys:String>
            <sys:String>Loan/Debt</sys:String>
            <sys:String>Advertising</sys:String>
            <sys:String>Equipment</sys:String>
            <sys:String>Revenue/Deposit</sys:String>
            <sys:String>Transfer</sys:String>
            <sys:String>Check</sys:String>
            <sys:String>Merchant Deposit</sys:String>
            <sys:String>ACH Credit</sys:String>
            <sys:String>ACH Debit</sys:String>
            <sys:String>Bill Pay</sys:String>
            <sys:String>POS Purchase</sys:String>
            <sys:String>POS Refund</sys:String>
            <sys:String>Credit Card Payment</sys:String>
            <sys:String>Wire Transfer</sys:String>
            <sys:String>Pre-Auth Debit</sys:String>
            <sys:String>Pre-Auth Credit</sys:String>
            <sys:String>Other</sys:String>
        </x:Array>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Bank Connection Panel (Plaid) -->
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Action Buttons -->
            <RowDefinition Height="Auto"/>  <!-- Summary Cards -->
            <RowDefinition Height="*"/>     <!-- TabControl -->
        </Grid.RowDefinitions>

        <!-- ═══ Bank Connection Status Panel (Plaid) ═══ -->
        <Border x:Name="bankConnectionPanel" Grid.Row="0"
                Background="#FF111118" BorderBrush="#FF222230" BorderThickness="1"
                CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bank icon -->
                <Border Grid.Column="0" Background="#22D4AF37" CornerRadius="8" Padding="10" Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="🏦" FontSize="24"/>
                </Border>

                <!-- Connection info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Connected state -->
                    <StackPanel x:Name="connectedInfo" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Connected: " Foreground="#FF8a8a9a" FontSize="12"/>
                            <TextBlock x:Name="txtBankName" Text="" Foreground="#FFD4AF37" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Last Sync: " Foreground="#FF8a8a9a" FontSize="11"/>
                            <TextBlock x:Name="txtLastSync" Text="Never" Foreground="#FFf0ece0" FontSize="11"/>
                            <TextBlock Text="  •  " Foreground="#FF8a8a9a" FontSize="11"/>
                            <Ellipse Width="8" Height="8" Fill="#FF22c55e" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Active" Foreground="#FF22c55e" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Disconnected state -->
                    <StackPanel x:Name="disconnectedInfo" Visibility="Visible">
                        <TextBlock Text="No Bank Connected" Foreground="#FF8a8a9a" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Connect your bank account to automatically sync transactions"
                                   Foreground="#FF666670" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Connected buttons -->
                    <StackPanel x:Name="connectedButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="btnSyncNow" Content="🔄 Sync Now"
                                Background="#FFD4AF37" Foreground="Black" FontWeight="Bold" FontSize="12"
                                Padding="14,8" Cursor="Hand" Click="SyncTransactions_Click"
                                BorderThickness="0">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button x:Name="btnViewBalance" Content="💰 Balance"
                                Background="#FF1a1a24" Foreground="#FFD4AF37" FontWeight="SemiBold" FontSize="12"
                                Padding="14,8" Margin="8,0,0,0" Cursor="Hand" Click="ViewBalance_Click"
                                BorderBrush="#FF222230" BorderThickness="1">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button x:Name="btnDisconnect" Content="❌"
                                Background="Transparent" Foreground="#FFef4444" FontSize="14"
                                Padding="8,6" Margin="8,0,0,0" Cursor="Hand" Click="DisconnectBank_Click"
                                BorderThickness="0" ToolTip="Disconnect Bank Account"/>
                    </StackPanel>

                    <!-- Disconnected button -->
                    <Button x:Name="btnConnectBank" Content="🔗 Connect Bank Account"
                            Background="#FFD4AF37" Foreground="Black" FontWeight="Bold" FontSize="12"
                            Padding="16,10" Cursor="Hand" Click="ConnectBank_Click"
                            BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Header -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Bank Statement" FontSize="24" FontWeight="SemiBold" Foreground="#FFD4AF37" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Month:" Foreground="#FF8a8a9a" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbMonth" Width="120" Height="32" Margin="0,0,8,0" SelectionChanged="Period_Changed"/>
                <TextBlock Text="Year:" Foreground="#FF8a8a9a" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbYear" Width="90" Height="32" SelectionChanged="Period_Changed"/>
            </StackPanel>
        </Grid>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="#FF13131a" BorderBrush="#FF222230" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnHome" Content="🏠 Dashboard" Click="Home_Click" MinWidth="130" Height="38" Margin="0,0,10,0"
                        Background="#FF222230" Foreground="#FFf0ece0" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnUpload" Content="📄 Upload Statement (Excel)" Click="Upload_Click" MinWidth="200" Height="38" Margin="0,0,10,0"
                        Background="#FFD4AF37" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnRefresh" Content="🔄 Refresh" Click="Refresh_Click" MinWidth="100" Height="38" Margin="0,0,10,0"
                        Background="#FF222230" Foreground="#FFf0ece0" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnRecategorize" Content="🏷 Re-Categorize All" Click="Recategorize_Click" MinWidth="160" Height="38" Margin="0,0,10,0"
                        Background="#FF222230" Foreground="#FFf0ece0" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        ToolTip="Re-run auto-categorization on all transactions for this month"/>
                <Button x:Name="btnSaveCategories" Content="💾 Save Categories" Click="SaveCategories_Click" MinWidth="140" Height="38" Margin="0,0,10,0"
                        Background="#FF1a4d1a" Foreground="#FF22c55e" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#FF22c55e" Cursor="Hand"
                        ToolTip="Save category changes to database"/>
                <Button x:Name="btnDeleteMonth" Content="🗑 Delete Month" Click="DeleteMonth_Click" MinWidth="130" Height="38"
                        Background="#FF3a1111" Foreground="#FFef4444" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#FFef4444" Cursor="Hand"/>
                <TextBlock x:Name="lblStatus" Foreground="#FF8a8a9a" VerticalAlignment="Center" Margin="20,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Summary Cards -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#FF13131a" BorderBrush="#FF222230" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Credits" Foreground="#FF22c55e" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="lblCredits" Text="$0.00" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#FF13131a" BorderBrush="#FF222230" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Debits" Foreground="#FFef4444" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="lblDebits" Text="$0.00" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#FF13131a" BorderBrush="#FF222230" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Net" Foreground="#FFD4AF37" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="lblNet" Text="$0.00" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="#FF13131a" BorderBrush="#FF222230" BorderThickness="1" CornerRadius="10" Padding="14">
                <StackPanel>
                    <TextBlock Text="Transactions" Foreground="#FF3b82f6" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="lblCount" Text="0" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tabs: Transactions / Check Reconciliation / Monthly Summary -->
        <TabControl Grid.Row="4" Background="#FF0B0B0F" BorderBrush="#FF222230" Foreground="#FFD4AF37">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#FF13131a"/>
                    <Setter Property="Foreground" Value="#FF8a8a9a"/>
                    <Setter Property="BorderBrush" Value="#FF222230"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tabBorder" Background="#FF13131a" BorderBrush="#FF222230" BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" Padding="14,8" Margin="0,0,2,0" Cursor="Hand">
                                    <TextBlock x:Name="tabText" Text="{TemplateBinding Header}" Foreground="#FF8a8a9a" FontWeight="SemiBold" FontSize="13"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#FF0B0B0F"/>
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#FFD4AF37"/>
                                        <Setter TargetName="tabText" Property="Foreground" Value="#FFD4AF37"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tabText" Property="Foreground" Value="#FFf0ece0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ═══ Transactions Tab ═══ -->
            <TabItem Header="Transactions">
                <DataGrid x:Name="gridTransactions" AutoGenerateColumns="False" IsReadOnly="False"
                          CanUserAddRows="False" SelectionMode="Single" RowHeight="32" FontSize="13"
                          Background="#FF0B0B0F" RowBackground="#FF0B0B0F" AlternatingRowBackground="#FF13131a"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FF222230">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:MM/dd/yyyy}}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="250" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip" Value="{Binding Description}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat={}{0:C2}}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat={}{0:C2}}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Check #" Binding="{Binding CheckNumber}" Width="85" IsReadOnly="True"/>
                        <!-- Editable Category ComboBox -->
                        <DataGridComboBoxColumn Header="Category" Width="170"
                                                SelectedItemBinding="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                                ItemsSource="{StaticResource PLCategories}"/>
                        <!-- Check Image viewer button — shown for every row that has a check number -->
                        <DataGridTemplateColumn Header="📷" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding CheckImageLabel}" FontSize="12" Cursor="Hand" 
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#FFD4AF37" ToolTip="View Check Image"
                                            Click="ViewCheckImage_Click"
                                            Visibility="{Binding CheckColumnVisibility}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ═══ Check Reconciliation Tab ═══ -->
            <TabItem Header="Check Reconciliation">
                <DataGrid x:Name="gridCheckRecon" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" SelectionMode="Single" RowHeight="32" FontSize="13"
                          Background="#FF0B0B0F" RowBackground="#FF0B0B0F" AlternatingRowBackground="#FF13131a"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FF222230">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:MM/dd/yyyy}}" Width="110"/>
                        <DataGridTextColumn Header="Check #" Binding="{Binding CheckNumber}" Width="100"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="250"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Debit, StringFormat={}{0:C2}}" Width="120"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding ReconcileStatus}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ═══ Monthly Summary Tab ═══ -->
            <TabItem Header="Monthly Summary">
                <DataGrid x:Name="gridSummary" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" SelectionMode="Single" RowHeight="32" FontSize="13"
                          Background="#FF0B0B0F" RowBackground="#FF0B0B0F" AlternatingRowBackground="#FF13131a"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FF222230">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Month" Binding="{Binding MonthLabel}" Width="120"/>
                        <DataGridTextColumn Header="Credits" Binding="{Binding TotalCredits, StringFormat={}{0:C2}}" Width="140"/>
                        <DataGridTextColumn Header="Debits" Binding="{Binding TotalDebits, StringFormat={}{0:C2}}" Width="140"/>
                        <DataGridTextColumn Header="Net" Binding="{Binding Net, StringFormat={}{0:C2}}" Width="140"/>
                        <DataGridTextColumn Header="Transactions" Binding="{Binding TransactionCount}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
