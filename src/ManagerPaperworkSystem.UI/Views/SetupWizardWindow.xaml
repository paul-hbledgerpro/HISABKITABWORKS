<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ManagerPaperworkSystem.UI.Converters"
        Title="HISAB KITAB - Initial Setup" Height="780" Width="650" MinHeight="700" MinWidth="600" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" 
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI">
  
  <Window.Resources>
    <conv:EnumDisplayConverter x:Key="EnumDisplayConverter"/>
    
    <!-- Local style for labels - Gold/White color -->
    <Style x:Key="FormLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>
    
    <!-- Section Header -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    
    <!-- Local style for TextBox - White background, gold border, black font -->
    <Style x:Key="FormTextBox" TargetType="TextBox">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    
    <!-- Local style for PasswordBox - White background, gold border, black font -->
    <Style x:Key="FormPasswordBox" TargetType="PasswordBox">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    
    <!-- Local style for ComboBox - White background, gold border, black font -->
    <Style x:Key="FormComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="TextElement.Foreground" Value="#FF000000"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    
    <!-- Animated Gold Button Style -->
    <Style x:Key="AnimatedGoldButton" TargetType="Button">
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="MinWidth" Value="100"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <Border x:Name="Shadow" CornerRadius="12" Background="#1A000000" Margin="0,3,0,0" Opacity="0.22"/>
              <Border x:Name="Bd" CornerRadius="12" BorderThickness="1" BorderBrush="#FFD4AF37">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFF5D6" Offset="0"/>
                    <GradientStop Color="#FFE8C872" Offset="0.55"/>
                    <GradientStop Color="#FFD4AF37" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFFFFFFF" Offset="0"/>
                      <GradientStop Color="#FFFFE9B0" Offset="0.55"/>
                      <GradientStop Color="#FFF1D27A" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFB68B1E" Offset="0"/>
                      <GradientStop Color="#FF9A7014" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    
    <!-- Secondary Button Style -->
    <Style x:Key="SecondaryButton" TargetType="Button">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="MinWidth" Value="90"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#FFD4AF37"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#FFD4AF37"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#22D4AF37"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="24,20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="0,0,0,10">
        <TextBlock Text="HISAB KITAB" FontSize="24" FontWeight="Bold" 
                   Foreground="{StaticResource AccentBrush}"/>
        <TextBlock Text="Initial Setup - Developer Configuration" FontSize="13" 
                   Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- ==================== DATABASE CONNECTION SECTION ==================== -->
      <Border Grid.Row="1" Background="#FF1A1A22" CornerRadius="10" Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="① DATABASE CONNECTION" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
          <TextBlock Text="Configure the SQL Server connection for this installation." 
                     Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,10"/>
          
          <!-- Database Type -->
          <TextBlock Text="Database Type:" Style="{StaticResource FormLabel}" Margin="0"/>
          <ComboBox x:Name="cmbDatabaseType" Style="{StaticResource FormComboBox}" SelectionChanged="DatabaseType_Changed">
            <ComboBoxItem Content="SQLite (Local - Single User)" Tag="SQLite"/>
            <ComboBoxItem Content="SQL Server (Network - Multi User)" Tag="SqlServer" IsSelected="True"/>
          </ComboBox>
          
          <!-- SQL Server Settings Panel -->
          <StackPanel x:Name="pnlSqlServer" Margin="0,10,0,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              
              <!-- Server -->
              <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="Server Address:" Style="{StaticResource FormLabel}" Margin="0"/>
                <TextBox x:Name="txtDbServer" Style="{StaticResource FormTextBox}" Text=".\SQLEXPRESS"/>
              </StackPanel>
              
              <!-- Database -->
              <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock Text="Database Name:" Style="{StaticResource FormLabel}" Margin="0"/>
                <TextBox x:Name="txtDbName" Style="{StaticResource FormTextBox}" Text="HisabKitab"/>
              </StackPanel>
              
              <!-- Username -->
              <StackPanel Grid.Row="1" Grid.Column="0">
                <TextBlock Text="SQL Username:" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="txtDbUsername" Style="{StaticResource FormTextBox}" Text=""/>
              </StackPanel>
              
              <!-- Password -->
              <StackPanel Grid.Row="1" Grid.Column="2">
                <TextBlock Text="SQL Password:" Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="txtDbPassword" Style="{StaticResource FormPasswordBox}"/>
              </StackPanel>
              
              <!-- Create Database + Test Connection -->
              <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,12,0,0">
                <Button x:Name="btnCreateDb" Content="Create Database" Style="{StaticResource AnimatedGoldButton}" 
                        MinWidth="140" Padding="14,8" Click="CreateDatabase_Click"/>
                <Button Content="Test Connection" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="TestConnection_Click"/>
                <TextBlock x:Name="txtConnectionStatus" VerticalAlignment="Center" Margin="12,0,0,0"/>
              </StackPanel>
            </Grid>
          </StackPanel>
          
          <!-- SQLite Info Panel -->
          <StackPanel x:Name="pnlSqlite" Visibility="Collapsed" Margin="0,10,0,0">
            <TextBlock Text="Database will be stored locally. Best for single-user installations." 
                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ==================== STORE INFORMATION SECTION ==================== -->
      <Border Grid.Row="2" Background="#FF1A1A22" CornerRadius="10" Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="② STORE INFORMATION" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
          
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="10"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
              <TextBlock Text="Store Name:" Style="{StaticResource FormLabel}" Margin="0"/>
              <TextBox x:Name="txtStoreName" Style="{StaticResource FormTextBox}"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2">
              <TextBlock Text="Default Report:" Style="{StaticResource FormLabel}" Margin="0"/>
              <ComboBox x:Name="cmbReportType" Style="{StaticResource FormComboBox}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" Foreground="#FF000000"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Grid>
          
          <TextBlock Text="Store Address:" Style="{StaticResource FormLabel}"/>
          <TextBox x:Name="txtStoreAddress" Style="{StaticResource FormTextBox}" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>
      </Border>

      <!-- ==================== ADMIN ACCOUNT SECTION ==================== -->
      <Border Grid.Row="3" Background="#FF1A1A22" CornerRadius="10" Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="③ ADMIN ACCOUNT" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
          <TextBlock Text="Create the owner/administrator account for this installation." 
                     Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,8"/>
          
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="10"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Name -->
            <StackPanel Grid.Row="0" Grid.Column="0">
              <TextBlock Text="First Name:" Style="{StaticResource FormLabel}" Margin="0"/>
              <TextBox x:Name="txtFirstName" Style="{StaticResource FormTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2">
              <TextBlock Text="Last Name:" Style="{StaticResource FormLabel}" Margin="0"/>
              <TextBox x:Name="txtLastName" Style="{StaticResource FormTextBox}"/>
            </StackPanel>
            
            <!-- Username -->
            <StackPanel Grid.Row="1" Grid.Column="0">
              <TextBlock Text="Admin Username:" Style="{StaticResource FormLabel}"/>
              <TextBox x:Name="txtUsername" Style="{StaticResource FormTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2">
              <TextBlock Text="Email Address:" Style="{StaticResource FormLabel}"/>
              <TextBox x:Name="txtEmail" Style="{StaticResource FormTextBox}"/>
            </StackPanel>
            
            <!-- Password -->
            <StackPanel Grid.Row="2" Grid.Column="0">
              <TextBlock Text="Admin Password:" Style="{StaticResource FormLabel}"/>
              <PasswordBox x:Name="pwd" Style="{StaticResource FormPasswordBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="2">
              <TextBlock Text="Confirm Password:" Style="{StaticResource FormLabel}"/>
              <PasswordBox x:Name="pwd2" Style="{StaticResource FormPasswordBox}"/>
            </StackPanel>
            
            <!-- Security Question -->
            <StackPanel Grid.Row="3" Grid.Column="0">
              <TextBlock Text="Security Question:" Style="{StaticResource FormLabel}"/>
              <ComboBox x:Name="cmbSecurityQuestion" Style="{StaticResource FormComboBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="2">
              <TextBlock Text="Security Answer:" Style="{StaticResource FormLabel}"/>
              <PasswordBox x:Name="pwdSecurityAnswer" Style="{StaticResource FormPasswordBox}"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ==================== ERROR AND BUTTONS ==================== -->
      <StackPanel Grid.Row="5" VerticalAlignment="Bottom">
        <TextBlock x:Name="lblError" Foreground="#FFFF6B6B" Margin="0,0,0,12" TextWrapping="Wrap" FontWeight="SemiBold"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource AnimatedGoldButton}" Width="110" Margin="0,0,12,0" Click="Cancel_Click"/>
          <Button Content="Complete Setup" Style="{StaticResource AnimatedGoldButton}" Width="150" Click="Save_Click"/>
        </StackPanel>
      </StackPanel>

    </Grid>
  </ScrollViewer>
</Window>
