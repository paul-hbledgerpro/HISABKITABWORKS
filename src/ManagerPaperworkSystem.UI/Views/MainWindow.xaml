d" Foreground="#FF000000"/> </Button> <Button Style="{StaticResource NavButton}" MinWidth="170" MinHeight="46" Margin="0,0,12,0" Padding="14,10" x:Name="btnNavPriceAlerts" Click="Nav_SelectTab_Click" CommandParameter="8"> <Button.Tag> <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF000000" Text="&#xE7BA;"/> </Button.Tag> <TextBlock Text="Price Alerts" FontWeight="SemiBold" Foreground="#FF000000"/> </Button> <Button x:Name="btnNavProfitLoss" Style="{StaticResource NavButton}" MinWidth="140" MinHeight="46" Margin="0,0,12,0" Padding="14,10" Click="Nav_SelectTab_Click" CommandParameter="9"> <Button.Tag> <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF000000" Text="&#xE9D9;"/> </Button.Tag> <TextBlock Text="P&amp;L" FontWeight="SemiBold" Foreground="#FF000000"/> </Button> <Button Style="{StaticResource NavButton}" MinWidth="170" MinHeight="46" Margin="0,0,0,0" Padding="14,10" Click="Reports_Click"> <Button.Tag> <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF000000" Text="&#xE749;"/> </Button.Tag> <TextBlock Text="Reports" FontWeight="SemiBold" Foreground="#FF000000"/> </Button> </StackPanel> </ScrollViewer> </Border> <!-- Main dashboard grid --> <Grid Grid.Row="2"> <Grid.ColumnDefinitions> <ColumnDefinition Width="2*"/> <ColumnDefinition Width="*"/> </Grid.ColumnDefinitions> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions> <!-- KPI Cards --> <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,12,12"> <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> </Grid.ColumnDefinitions> <!-- Cash On Hand --> <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="{StaticResource TileShimmerBrush}" CornerRadius="12" Padding="14" Margin="0,0,10,0"> <Grid> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions> <Grid Grid.Row="0"> <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions> <TextBlock Text="Cash On Hand" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/> <TextBlock x:Name="btnRefreshCash" Grid.Column="1" Text="⟳" FontSize="16" Foreground="#FFD4AF37" ToolTip="Refresh" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonDown="RefreshCash_Click"/> </Grid> <TextBlock Grid.Row="1" x:Name="dashCash" Text="$0.00" Foreground="{StaticResource WhiteTextBrush}" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/> <TextBlock Grid.Row="2" Text="Current store balance" Foreground="{StaticResource WhiteTextBrush}" Margin="0,4,0,0"/> </Grid> </Border> <!-- Uncleared Checks --> <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource TileShimmerBrush}" CornerRadius="12" Padding="14" Margin="0,0,10,0"> <Grid> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions> <Grid Grid.Row="0"> <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions> <TextBlock Text="Uncleared Checks" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/> <TextBlock x:Name="btnRefreshChecks" Grid.Column="1" Text="⟳" FontSize="16" Foreground="#FFD4AF37" ToolTip="Refresh" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonDown="RefreshChecks_Click"/> </Grid> <TextBlock Grid.Row="1" x:Name="dashChecks" Text="$0.00" Foreground="{StaticResource WhiteTextBrush}" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/> <TextBlock Grid.Row="2" Text="Pending payouts" Foreground="{StaticResource WhiteTextBrush}" Margin="0,4,0,0"/> </Grid> </Border> <!-- Price Alerts --> <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="{StaticResource TileShimmerBrush}" CornerRadius="12" Padding="14"> <Grid> <Grid.RowDefinition