rigger Property="IsMouseOver" Value="True"><Setter TargetName="logoBorder" Property="Opacity" Value="0.85"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button> <!-- Home button --> <!-- Home button removed - logo acts as home button --> <!-- Spacer --> <Border Grid.Column="2"/> <!-- Store selector --> <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"> <TextBlock Text="Store:" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold" FontSize="14" Opacity="0.95"/> <ComboBox x:Name="cmbStore" Width="240" MinWidth="240" Height="44" FontSize="14" SelectionChanged="Store_SelectionChanged" DisplayMemberPath="Name" SelectedValuePath="Id" Background="{DynamicResource FieldBrush}" Foreground="#FF000000" BorderThickness="0"> <ComboBox.Effect> <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2"/> </ComboBox.Effect> </ComboBox> <Button x:Name="btnStores" Content="Stores..." MinWidth="120" Height="44" Margin="12,0,0,0" Click="ManageStores_Click" FontWeight="SemiBold" FontSize="14" Cursor="Hand" Background="{DynamicResource FieldBrush}" BorderThickness="0"> <Button.Effect> <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2"/> </Button.Effect> </Button> </StackPanel> </Grid> </Border> <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"> <StatusBarItem> <TextBlock x:Name="lblStore" FontWeight="SemiBold"/> </StatusBarItem> <StatusBarItem HorizontalAlignment="Right"> <TextBlock x:Name="lblDbPath" Opacity="0.7"/> </StatusBarItem> </StatusBar> <Grid Margin="14"> <!-- Dashboard-only navigation (Option B): tabs remain for modules, but headers are hidden. --> <TabControl x:Name="tabsMain" ItemContainerStyle="{StaticResource HiddenTabItem}" SelectionChanged="TabsMain_SelectionChanged"> <!-- DASHBOARD --> <TabItem Header="Dashboard"> <Border Background="#FF0B0B0F" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" CornerRadius="10" Padding="2"> <