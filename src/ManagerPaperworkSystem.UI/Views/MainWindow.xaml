<!-- PROFIT & LOSS -->
<TabItem Header="Profit Loss">
<Border Background="#FF0B0B0F" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" CornerRadius="10" Padding="2">
<Grid Margin="12">
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
</Grid.RowDefinitions>

<!-- Header with Month/Year Selectors -->
<Grid Grid.Row="0" Margin="0,0,0,15">
<Grid.ColumnDefinitions>
<ColumnDefinition Width="*"/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>
<TextBlock Text="Profit &amp; Loss Statement" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
    <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
    <ComboBox x:Name="cmbPlMonth" Width="120" Margin="0,0,10,0" DisplayMemberPath="Value" SelectedValuePath="Key"/>
    <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,6,0"/>
    <ComboBox x:Name="cmbPlYear" Width="80" Margin="0,0,10,0"/>
    <CheckBox x:Name="chkPlYearly" Content="Full Year" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
    <Button x:Name="btnPlRefresh" Content="📊 Calculate" Style="{StaticResource PrimaryButton}" Width="120" Height="35" Click="PL_Refresh_Click"/>
</StackPanel>
</Grid>

<!-- Home button -->
<Button Grid.Row="1" Content="🏠 Go to Dashboard" Style="{StaticResource SecondaryButton}" Height="36" HorizontalAlignment="Left" Margin="0,0,0,15" Click="Nav_SelectTab_Click" CommandParameter="0"/>

<!-- P&L Content -->
<Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20">
<ScrollViewer VerticalScrollBarVisibility="Auto">
<Grid>
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>

<!-- Revenue Section -->
<Border Grid.Row="0" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,15">
<Grid>
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>
<TextBlock Text="REVENUE" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
<Grid Grid.Row="1" Margin="20,0,0,5">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Gross Sales (Net Sales)" Foreground="White"/>
<TextBlock x:Name="plGrossSales" Grid.Column="1" Text="$0.00" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid Grid.Row="2" Margin="20,0,0,5">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Sales Tax Collected" Foreground="White"/>
<TextBlock x:Name="plSalesTax" Grid.Column="1" Text="$0.00" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plBankDepositsRow" Grid.Row="3" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Bank Deposits / Income" Foreground="#FF22c55e"/>
<TextBlock x:Name="plBankDeposits" Grid.Column="1" Text="$0.00" Foreground="#FF22c55e" HorizontalAlignment="Right"/>
</Grid>
<Border Grid.Row="4" Background="#FF2A2A32" Margin="0,10,0,0" Padding="10">
<Grid>
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Total Revenue" FontWeight="Bold" Foreground="White"/>
<TextBlock x:Name="plTotalRevenue" Grid.Column="1" Text="$0.00" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
</Border>
</Grid>
</Border>

<!-- Manual Expenses Section -->
<Border Grid.Row="1" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,15">
<Grid>
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>
<TextBlock Text="COST OF GOODS &amp; EXPENSES" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
<Grid Grid.Row="1" Margin="20,0,0,5">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Purchases / Inventory Cost" Foreground="White"/>
<TextBlock x:Name="plPurchases" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid Grid.Row="2" Margin="20,0,0,5">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Cash Payouts" Foreground="White"/>
<TextBlock x:Name="plCashPayouts" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid Grid.Row="3" Margin="20,0,0,5">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Check Payouts" Foreground="White"/>
<TextBlock x:Name="plCheckPayouts" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
</Grid>
</Border>

<!-- Bank Statement Expenses (hidden if no data) -->
<Border x:Name="plBankExpenseHeader" Grid.Row="2" Background="#FF1A1A22" CornerRadius="8" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
<Grid>
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>
<TextBlock Text="BANK STATEMENT EXPENSES" FontWeight="Bold" FontSize="14" Foreground="#FF3b82f6" Margin="0,0,0,10"/>
<Grid x:Name="plUtilitiesRow" Grid.Row="1" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Utilities" Foreground="White"/><TextBlock x:Name="plUtilities" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plRentRow" Grid.Row="2" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Rent / Lease" Foreground="White"/><TextBlock x:Name="plRent" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plPayrollRow" Grid.Row="3" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Payroll / Wages" Foreground="White"/><TextBlock x:Name="plPayroll" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plInsuranceRow" Grid.Row="4" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Insurance" Foreground="White"/><TextBlock x:Name="plInsurance" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plBankFeesRow" Grid.Row="5" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Bank Fees / Service Charges" Foreground="White"/><TextBlock x:Name="plBankFees" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plTaxesRow" Grid.Row="6" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Taxes" Foreground="White"/><TextBlock x:Name="plTaxes" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plLoanDebtRow" Grid.Row="7" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Loan / Debt Payments" Foreground="White"/><TextBlock x:Name="plLoanDebt" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
<Grid x:Name="plOtherBankRow" Grid.Row="8" Margin="20,0,0,5" Visibility="Collapsed">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Other Bank Expenses" Foreground="White"/><TextBlock x:Name="plOtherBank" Grid.Column="1" Text="($0.00)" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
</Grid>
</Border>

<!-- Total Expenses -->
<Border Grid.Row="3" Background="#FF2A2A32" CornerRadius="6" Padding="10,8" Margin="0,0,0,15">
<Grid>
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
<TextBlock Text="Total Expenses" FontWeight="Bold" Foreground="White"/>
<TextBlock x:Name="plTotalExpenses" Grid.Column="1" Text="($0.00)" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
</Grid>
</Border>

<!-- Net Profit/Loss -->
<Border Grid.Row="4" x:Name="plResultBorder" Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="20">
<Grid>
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
<TextBlock Text="NET PROFIT / (LOSS)" FontWeight="Bold" FontSize="16" Foreground="Black" VerticalAlignment="Center"/>
<TextBlock x:Name="plNetResult" Grid.Column="1" Text="$0.00" FontWeight="Bold" FontSize="24" Foreground="Black"/>
</Grid>
</Border>

<!-- Buttons & Error -->
<StackPanel Grid.Row="5" Margin="0,20,0,0">
<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
<Button x:Name="btnPlReport" Content="Generate P&amp;L Report (PDF)" Style="{StaticResource PrimaryButton}" Width="200" Height="40" Click="PL_GenerateReport_Click"/>
</StackPanel>
<TextBlock x:Name="plError" Foreground="#FFFF6B6B" TextWrapping="Wrap" Margin="0,10,0,0"/>
</StackPanel>
</Grid>
</ScrollViewer>
</Border>
</Grid>
</Border>
</TabItem>
</TabControl> </Grid> </DockPanel>
