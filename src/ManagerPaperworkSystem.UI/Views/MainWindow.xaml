"RefreshInvoice_Click"/> </Grid> <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"> <Ellipse Width="160" Height="160" Fill="#FF1A1A22"/> <Ellipse Width="110" Height="110" Fill="#FF0B0B0F"/> <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"> <TextBlock x:Name="dashInvoiceCount" Text="0" TextAlignment="Center" Foreground="{StaticResource AccentBrush}" FontSize="32" FontWeight="Bold"/> <TextBlock Text="Invoices" TextAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/> </StackPanel> </Grid> <StackPanel Grid.Row="2" Margin="0,8,0,0"> <TextBlock x:Name="dashInvoiceTotal" Text="Total: $0.00" Foreground="{StaticResource WhiteTextBrush}" FontWeight="SemiBold"/> <TextBlock x:Name="dashInvoiceThisMonth" Text="This Month: $0.00" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/> <TextBlock x:Name="dashInvoiceVendors" Text="Vendors: 0" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/> </StackPanel> </Grid> </Border> <!-- Sales Trend (left) --> <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,12,12"> <Grid> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> </Grid.RowDefinitions> <Grid Grid.Row="0"> <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions> <TextBlock Text="Sales Summary (Daily)" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/> <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"> <Rectangle Width="10" Height="10" Fill="#2F6BFF" Margin="0,0,6,0"/> <TextBlock Text="This Year" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0"/> <Rectangle Width="10" Height="10" Fill="#A9C2FF" Margin="0,0,6,0"/> <TextBlock Text="YoY" Foreground="{StaticResource MutedTextBrush}"/> </StackPanel> </Grid> <!-- Keep existing named bars so the code-behind continues to update them --> <UniformGrid Grid.Row="1" Columns="12" VerticalAlignment="Bottom" Margin="0,14,0,0" Height="180"> <Rectangle x:Name="salesBar01" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="40" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar02" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="55" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar03" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="46" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar04" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="62" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar05" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="50" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar06" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="70" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar07" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="58" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar08" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="74" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar09" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="52" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar10" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="82" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar11" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="60" Margin="2,0" VerticalAlignment="Bottom"/> <Rectangle x:Name="salesBar12" Fill="#2F6BFF" RadiusX="3" RadiusY="3" Height="90" Margin="2,0" VerticalAlignment="Bottom"/> </UniformGrid> </Grid> </Border> <!-- Recent Price Changes Table (right) --> <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12"> <Grid> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> </Grid.RowDefinitions> <Grid Grid.Row="0"> <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions> <TextBlock Text="Recent Price Changes" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/> <TextBlock x:Name="btnRefreshPriceChanges" Grid.Column="1" Text="⟳" FontSize="16" Foreground="#FFD4AF37" ToolTip="Refresh" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonDown="RefreshPriceChanges_Click"/> </Grid> <DataGrid Grid.Row="1" x:Name="gridDashPriceAlerts" Margin="0,10,0,0" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" IsReadOnly="True" Height="240" Background="#FF0B0B0F" RowBackground="#FF0B0B0F"> <DataGrid.Columns> <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/> <DataGridTextColumn Header="Old" Binding="{Binding OldUnitCost, StringFormat=C2}" Width="55"/> <DataGridTextColumn Header="New" Binding="{Binding NewUnitCost, StringFormat=C2}" Width="55"/> <DataGridTextColumn Header="Chg" Binding="{Binding Direction}" Width="35"/> </DataGrid.Columns> </DataGrid> </Grid> </Border> <!-- Bottom row removed - Recent Entries section removed per request --> </Grid> </Grid> </Border> </TabItem> <!-- SHIFT LOG --> <TabItem Header="Shift Cash Drop"> <Border Background="#FF0B0B0F" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" CornerRadius="10" Padding="2"> <Grid Margin="10"> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> </Grid.RowDefinitions> <!-- Entry form --> <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="18" CornerRadius="20"> <Grid> <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions> <Grid.ColumnDefinitions> <ColumnDefinition Width="140"/> <ColumnDefinition Width="360"/> <ColumnDefinition Width="40"/> <ColumnDefinition Width="140"/> <ColumnDefinition Width="360"/> </Grid.ColumnDefinitions> <TextBlock Grid.Row="0" Grid.Column="0" Text="Date" 