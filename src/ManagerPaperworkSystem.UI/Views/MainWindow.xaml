            <TabItem Header="Purchases">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Grid Margin="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  
                  <!-- Entry Form -->
                  <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="18" CornerRadius="20">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      
                      <!-- Row 0: Date and Invoice Number -->
                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Invoice Date" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                      <DatePicker Grid.Row="0" Grid.Column="1" x:Name="invDate" Style="{StaticResource GoldDatePicker}" Height="46" VerticalAlignment="Center"/>
                      
                      <TextBlock Grid.Row="0" Grid.Column="3" Text="Invoice #" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                      <TextBox Grid.Row="0" Grid.Column="4" x:Name="invNumber" Height="38" VerticalAlignment="Center"/>
                      
                      <!-- Row 2: Invoice Total and Vendor -->
                      <TextBlock Grid.Row="2" Grid.Column="0" Text="Invoice Total" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                      <TextBox Grid.Row="2" Grid.Column="1" x:Name="invTotal" Height="38" VerticalAlignment="Center"/>
                      
                      <TextBlock Grid.Row="2" Grid.Column="3" Text="Vendor" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                      <ComboBox Grid.Row="2" Grid.Column="4" x:Name="invVendor" Height="38" VerticalAlignment="Center" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                      
                      <!-- Row 4: Buttons -->
                      <UniformGrid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Columns="7" Height="44" Margin="0,8,0,0">
                        <Button Content="🏠 Home" Style="{StaticResource SecondaryButton}" Click="Nav_SelectTab_Click" CommandParameter="0" Margin="4,0"/>
                        <Button x:Name="btnInvImportPdf" Content="📄 Import PDF" Style="{StaticResource PrimaryButton}" Click="Inv_ImportPdf_Click" Margin="4,0"/>
                        <Button x:Name="btnInvAdd" Content="Add Invoice" Style="{StaticResource PrimaryButton}" Click="Inv_Add_Click" Margin="4,0"/>
                        <Button x:Name="btnInvUpdate" Content="Update Selected" Style="{StaticResource PrimaryButton}" Click="Inv_Update_Click" Margin="4,0"/>
                        <Button x:Name="btnInvDelete" Content="Delete Selected" Style="{StaticResource PrimaryButton}" Click="Inv_Delete_Click" Margin="4,0"/>
                        <Button x:Name="btnInvClear" Content="Clear Form" Style="{StaticResource PrimaryButton}" Click="Inv_Clear_Click" Margin="4,0"/>
                        <Button x:Name="btnInvRefresh" Content="Refresh" Style="{StaticResource PrimaryButton}" Click="Inv_Refresh_Click" Margin="4,0"/>
                      </UniformGrid>
                    </Grid>
                  </Border>
                  
                  <!-- Error Message -->
                  <TextBlock Grid.Row="1" x:Name="invError" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,8,0,8"/>
                  
                  <!-- Hidden fields required by code-behind -->
                  <TextBox x:Name="invVendorName" Visibility="Collapsed"/>
                  <TextBox x:Name="invFilePath" Visibility="Collapsed"/>
                  <TextBox x:Name="invNotes" Visibility="Collapsed"/>
                  <TextBlock x:Name="invImportStatus" Visibility="Collapsed"/>
                  <CheckBox x:Name="chkInvAllowEdits" Visibility="Collapsed"/>
                  <DataGrid x:Name="gridInvoiceLines" Visibility="Collapsed"/>
                  <Button x:Name="btnInvImportAll" Visibility="Collapsed"/>
                  
                  <!-- Monthly Entries Grid -->
                  <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14" Margin="0,8,0,0">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                      </Grid.RowDefinitions>
                      
                      <TextBlock Grid.Row="0" Text="Invoice Entries (Monthly)" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                      
                      <DataGrid Grid.Row="1" x:Name="gridInvoices" SelectionMode="Extended" MinHeight="400" IsReadOnly="True"  AutoGenerateColumns="False" SelectionChanged="Invoices_SelectionChanged" CanUserResizeColumns="True">
                        <DataGrid.Columns>
                          <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat={}{0:MM/dd/yyyy}}" Width="120" MinWidth="100"/>
                          <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="180" MinWidth="150"/>
                          <DataGridTextColumn Header="Vendor" Binding="{Binding VendorName}" Width="*" MinWidth="350"/>
                          <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:C}}" Width="150" MinWidth="120"/>
                        </DataGrid.Columns>
                      </DataGrid>
                    </Grid>
                  </Border>
                </Grid>
              </ScrollViewer>
