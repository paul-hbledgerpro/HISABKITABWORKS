<Window x:Class="ManagerPaperworkSystem.UI.Views.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hisab Kitab — License Activation"
        Width="520" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B0B0F">

    <Window.Resources>
        <SolidColorBrush x:Key="Gold" Color="#D4AF37"/>
        <SolidColorBrush x:Key="GoldDim" Color="#40D4AF37"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#222230"/>
        <SolidColorBrush x:Key="ErrorRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22C55E"/>

        <Style x:Key="TBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0B0B0F"/>
            <Setter Property="Foreground" Value="#F0ECE0"/>
            <Setter Property="BorderBrush" Value="#222230"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#D4AF37"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A8A9A"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,24,36,24">

                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Width="56" Height="56" CornerRadius="28"
                            BorderBrush="{StaticResource Gold}" BorderThickness="2"
                            Background="{StaticResource GoldDim}" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F511;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="HISAB KITAB" FontSize="18" FontWeight="Black"
                               Foreground="{StaticResource Gold}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="LICENSE ACTIVATION" FontSize="11" Foreground="#8A8A9A"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Store Information -->
                <Border Background="#13131A" BorderBrush="#222230" BorderThickness="1"
                        CornerRadius="10" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="STORE INFORMATION" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource Gold}" Margin="0,0,0,12"/>

                        <TextBlock Style="{StaticResource Lbl}" Text="STORE / BUSINESS NAME *"/>
                        <TextBox x:Name="txtStoreName" Style="{StaticResource TBox}" Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource Lbl}" Text="STORE ADDRESS"/>
                        <TextBox x:Name="txtStoreAddress" Style="{StaticResource TBox}" Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource Lbl}" Text="STORE ZIP CODE"/>
                        <TextBox x:Name="txtStoreZip" Style="{StaticResource TBox}" MaxLength="10"/>
                    </StackPanel>
                </Border>

                <!-- License Key -->
                <Border Background="#13131A" BorderBrush="#222230" BorderThickness="1"
                        CornerRadius="10" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="LICENSE KEY" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource Gold}" Margin="0,0,0,12"/>

                        <TextBlock Style="{StaticResource Lbl}" Text="ENTER LICENSE KEY *"/>
                        <TextBox x:Name="txtLicenseKey" Style="{StaticResource TBox}"
                                 FontFamily="Consolas" FontSize="16" CharacterCasing="Upper" MaxLength="18"/>
                        <TextBlock Text="Format: HBL-XXXX-XXXX-XXXX" FontSize="10" Foreground="#555"
                                   Margin="0,4,0,0"/>
                        <Button Content="IMPORT OFFLINE LICENSE FILE"
                                Click="ImportOfflineLicense_Click"
                                HorizontalAlignment="Stretch" Margin="0,12,0,0"
                                FontWeight="Bold" FontSize="12" Padding="14,10" Cursor="Hand"
                                BorderThickness="1" BorderBrush="{StaticResource Gold}"
                                Background="Transparent" Foreground="{StaticResource Gold}"/>
                    </StackPanel>
                </Border>

                <!-- Progress -->
                <ProgressBar x:Name="progressBar" IsIndeterminate="True" Height="4"
                             Foreground="{StaticResource Gold}" Background="#222230"
                             Visibility="Collapsed" Margin="0,0,0,8"/>

                <!-- Activate Button -->
                <Button x:Name="btnActivate" Content="ACTIVATE LICENSE"
                        Click="Activate_Click" HorizontalAlignment="Stretch"
                        FontWeight="Bold" FontSize="14" Padding="18,14" Cursor="Hand"
                        BorderThickness="0" Foreground="Black">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="#D4AF37" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E5C040"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Status -->
                <Border x:Name="statusBorder" Visibility="Collapsed" CornerRadius="8"
                        Padding="14" Margin="0,12,0,0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="txtStatus" FontSize="13" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtStatusDetail" FontSize="11" Foreground="#8A8A9A"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Cancel -->
                <Button x:Name="btnCancel" Content="Cancel" Click="Cancel_Click"
                        HorizontalAlignment="Stretch" Margin="0,12,0,0"
                        FontWeight="Bold" FontSize="13" Padding="14,12" Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#222230" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#8A8A9A"/>
                    </Button.Foreground>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
