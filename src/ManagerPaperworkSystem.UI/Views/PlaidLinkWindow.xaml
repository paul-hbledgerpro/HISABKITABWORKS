<Window x:Class="ManagerPaperworkSystem.UI.Views.PlaidLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Connect Bank Account — Hisab Kitab"
        Width="480" Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF0B0B0F">
    <Grid>
        <!-- Header -->
        <Border VerticalAlignment="Top" Height="50" Background="#FF111118" BorderBrush="#FFD4AF37" BorderThickness="0,0,0,2" Panel.ZIndex="5">
            <TextBlock Text="🏦  Connect Your Bank Account" Foreground="#FFD4AF37" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="plaidWebView" Margin="0,50,0,0"/>

        <!-- Loading overlay -->
        <Border x:Name="loadingOverlay" Background="#FF0B0B0F" Panel.ZIndex="10" Margin="0,50,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🏦" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Loading secure bank login..." Foreground="#FFD4AF37" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Please wait..." Foreground="#FF8a8a9a" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
