<Window Icon="pack://application:,,,/Assets/HisabKitab.ico" x:Class="ManagerPaperworkSystem.UI.Views.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HISAB KITAB - Reset Password" Height="620" Width="500" MinWidth="500" MinHeight="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI">

  <Window.Resources>
    <!-- Local style for labels - Gold color -->
    <Style x:Key="FormLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,12,0,4"/>
    </Style>
    
    <!-- Local style for TextBox - White background, gold border, black font -->
    <Style x:Key="FormTextBox" TargetType="TextBox">
      <Setter Property="Height" Value="38"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <!-- Local style for PasswordBox - White background, gold border, black font -->
    <Style x:Key="FormPasswordBox" TargetType="PasswordBox">
      <Setter Property="Height" Value="38"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <!-- Animated Gold Button Style with Black Text -->
    <Style x:Key="AnimatedGoldButton" TargetType="Button">
      <Setter Property="Height" Value="42"/>
      <Setter Property="Padding" Value="20,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="#FF000000"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <Border x:Name="Shadow" CornerRadius="12" Background="#1A000000" Margin="0,2,0,0" Opacity="0.22"/>
              <Border x:Name="Bd" CornerRadius="12" BorderThickness="1" BorderBrush="#FFD4AF37">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFE9B0" Offset="0"/>
                    <GradientStop Color="#FFD4AF37" Offset="0.55"/>
                    <GradientStop Color="#FFB68B1E" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                  <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.14" Color="#FFD4AF37"/>
                </Border.Effect>
                <Grid>
                  <Border x:Name="Gloss" CornerRadius="12" Margin="1" Opacity="0.25" IsHitTestVisible="False">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                        <GradientStop Color="#55FFFFFF" Offset="0.28"/>
                        <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>
                  <Rectangle x:Name="ShimmerX" IsHitTestVisible="False" Opacity="0" RadiusX="12" RadiusY="12">
                    <Rectangle.Fill>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                        <GradientStop Color="#44FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                      </LinearGradientBrush>
                    </Rectangle.Fill>
                  </Rectangle>
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" TextElement.Foreground="#FF1A1A1A"/>
                </Grid>
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFFFFFFF" Offset="0"/>
                      <GradientStop Color="#FFFFE9B0" Offset="0.55"/>
                      <GradientStop Color="#FFF1D27A" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
                <Setter TargetName="ShimmerX" Property="Opacity" Value="0.4"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFB68B1E" Offset="0"/>
                      <GradientStop Color="#FF9A7014" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Margin="20" Padding="20" CornerRadius="16" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0B0B0F" Offset="0"/>
        <GradientStop Color="#FF151518" Offset="0.5"/>
        <GradientStop Color="#FF0B0B0F" Offset="1"/>
      </LinearGradientBrush>
    </Border.Background>
    
    <StackPanel>
      <!-- Title -->
      <TextBlock Text="Reset Password" FontSize="22" FontWeight="Bold" 
                 Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"
                 HorizontalAlignment="Center"/>
      
      <TextBlock Text="Enter your username and security answer to reset your password" 
                 FontSize="11" Foreground="{StaticResource MutedTextBrush}" 
                 HorizontalAlignment="Center" Margin="0,0,0,16" TextWrapping="Wrap" TextAlignment="Center"/>

      <!-- Username -->
      <TextBlock Text="Username" Style="{StaticResource FormLabel}"/>
      <TextBox x:Name="txtTargetUser" Style="{StaticResource FormTextBox}"/>

      <!-- New Password Row -->
      <Grid Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="New Password" Style="{StaticResource FormLabel}"/>
          <PasswordBox x:Name="pwdNew" Style="{StaticResource FormPasswordBox}"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Confirm Password" Style="{StaticResource FormLabel}"/>
          <PasswordBox x:Name="pwdConfirm" Style="{StaticResource FormPasswordBox}"/>
        </StackPanel>
      </Grid>

      <!-- Divider -->
      <Border Margin="0,20,0,12" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,1,0,0" Opacity="0.5"/>

      <!-- Security Section -->
      <TextBlock Text="Security Verification" FontWeight="Bold" FontSize="14"
                 Foreground="{StaticResource WhiteTextBrush}" Margin="0,0,0,4"/>

      <TextBlock Text="Security Question" Style="{StaticResource FormLabel}"/>
      <Border Background="#FF151518" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
              CornerRadius="6" Padding="10,8" MinHeight="38">
        <TextBlock x:Name="txtSecurityQuestion" TextWrapping="Wrap" VerticalAlignment="Center"
                   Foreground="{StaticResource MutedTextBrush}" FontStyle="Italic"/>
      </Border>

      <TextBlock Text="Your Answer" Style="{StaticResource FormLabel}"/>
      <PasswordBox x:Name="pwdSecurityAnswer" Style="{StaticResource FormPasswordBox}"/>

      <!-- Error Message -->
      <TextBlock x:Name="lblError" Foreground="#FFFF6B6B" TextWrapping="Wrap" Margin="0,12,0,0" FontSize="11"/>

      <!-- Buttons -->
      <Grid Margin="0,20,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="Cancel" Style="{StaticResource AnimatedGoldButton}" Click="Cancel_Click"/>
        <Button Grid.Column="2" Content="Reset Password" Style="{StaticResource AnimatedGoldButton}" Click="Reset_Click"/>
      </Grid>
    </StackPanel>
  </Border>
</Window>
