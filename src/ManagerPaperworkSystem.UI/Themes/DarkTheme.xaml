<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!--
    Dark theme + neon green for Tab headers and dropdown menus.

    WPF popups (ComboBox dropdown list, DatePicker calendar) often use SystemColors.
    Overriding them ensures dropdown text stays visible on dark backgrounds.
  -->

  <!-- System colors for popup/dropdown surfaces -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF151922"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF1C2230"/>

  <!-- Make dropdown/menu text neon green -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FF39FF14"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF39FF14"/>

  <!-- Selection highlight -->
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF39FF14"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF0F1115"/>

  <!-- Palette -->
  <Color x:Key="BgColor">#FF0F1115</Color>
  <Color x:Key="PanelColor">#FF151922</Color>
  <Color x:Key="ControlColor">#FF1C2230</Color>
  <Color x:Key="AccentColor">#FF39FF14</Color>
  <Color x:Key="BorderColor">#FF2A3142</Color>
  <Color x:Key="TextColor">#FFF2F5FF</Color>
  <Color x:Key="NeonColor">#FF39FF14</Color>

  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="ControlBrush" Color="{StaticResource ControlColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="NeonBrush" Color="{StaticResource NeonColor}"/>

  <!-- Accent-aware 3D button gradient. ThemeManager replaces this brush when the user switches theme colors. -->
  <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF59FF3A" Offset="0"/>
    <GradientStop Color="#FF27D90A" Offset="1"/>
  </LinearGradientBrush>

  <!-- Global defaults -->
  <Style TargetType="Window">
    <Setter Property="WindowStyle" Value="SingleBorderWindow"/>
    <Setter Property="ResizeMode" Value="CanResize"/>
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <!-- Common 3D shadow for controls -->
  <DropShadowEffect x:Key="ControlShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.35"/>

  <Style TargetType="TextBox">
    <!-- Slight 3D look: subtle gradient + shadow -->
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FF232B3A" Offset="0"/>
          <GradientStop Color="#FF171D2A" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="CaretBrush" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
  </Style>

  <Style TargetType="PasswordBox">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FF232B3A" Offset="0"/>
          <GradientStop Color="#FF171D2A" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="CaretBrush" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,5"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
  </Style>

  <!-- Dropdown menus -->
  <!-- Dropdown menus -->
  <Style TargetType="ComboBox">
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FF232B3A" Offset="0"/>
          <GradientStop Color="#FF171D2A" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"/>
            <DockPanel Margin="1">
              <ToggleButton x:Name="Toggle"
                            DockPanel.Dock="Right"
                            Focusable="False"
                            Width="30"
                            Background="Transparent"
                            BorderThickness="0"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <Grid>
                  <Path Data="M 0 0 L 4 4 L 8 0 Z"
                        Fill="{DynamicResource NeonBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Grid>
              </ToggleButton>

              <!-- Selected value (non-editable) -->
              <ContentPresenter x:Name="ContentSite"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />

              <!-- Editable text -->
              <TextBox x:Name="PART_EditableTextBox"
                       Margin="{TemplateBinding Padding}"
                       Background="Transparent"
                       Foreground="{TemplateBinding Foreground}"
                       CaretBrush="{DynamicResource NeonBrush}"
                       BorderThickness="0"
                       Visibility="Hidden"
                       IsReadOnly="{TemplateBinding IsReadOnly}"/>
            </DockPanel>

            <Popup x:Name="Popup"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   Focusable="False"
                   PopupAnimation="Fade">
              <Border Background="{StaticResource ControlBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      SnapsToDevicePixels="True">
                <ScrollViewer Margin="0"
                              SnapsToDevicePixels="True"
                              CanContentScroll="True">
                  <ItemsPresenter/>
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
            </Trigger>
            <Trigger Property="IsEditable" Value="True">
              <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
              <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="Padding" Value="8,6"/>
  </Style>

  <!-- Force DatePicker textbox (selected date) to neon on dark -->
  <Style TargetType="DatePickerTextBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="CaretBrush" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
  </Style>

  <!-- Calendar style used by DatePicker popup (explicit so it never falls back to light theme) -->
  <Style x:Key="NeonCalendarStyle" TargetType="Calendar" BasedOn="{StaticResource {x:Type Calendar}}">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6"/>
  </Style>

  <Style TargetType="DatePicker">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FF232B3A" Offset="0"/>
          <GradientStop Color="#FF171D2A" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,5"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
    <Setter Property="CalendarStyle" Value="{StaticResource NeonCalendarStyle}"/>
  </Style>

  <Style TargetType="CalendarItem">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
  </Style>

  <!-- Calendar popup (DatePicker) - explicit styles so it's never "blank" on dark theme -->
  <Style TargetType="Calendar">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6"/>
  </Style>

  <Style TargetType="CalendarDayButton">
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CalendarDayButton">
          <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NeonBrush}"/>
              <Setter Property="Foreground" Value="{StaticResource BgBrush}"/>
            </Trigger>
            <Trigger Property="IsInactive" Value="True">
              <Setter Property="Foreground" Value="#FF7DFF66"/>
              <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
            </Trigger>
            <Trigger Property="IsToday" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
            </Trigger>
            <Trigger Property="IsBlackedOut" Value="True">
              <Setter Property="Foreground" Value="#FF444A5A"/>
              <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="CalendarButton">
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CalendarButton">
          <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#FF1F2838"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Button">
    <!-- 3D neon button -->
    <Setter Property="Background" Value="{DynamicResource AccentButtonBrush}"/>
    <Setter Property="Foreground" Value="#FF0B0E12"/>
    <Setter Property="BorderBrush" Value="#FF0B0E12"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="RenderTransform">
                <Setter.Value>
                  <TranslateTransform Y="1"/>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Bd" Property="Opacity" Value="0.95"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="DataGrid">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="RowBackground" Value="{StaticResource PanelBrush}"/>
    <Setter Property="AlternatingRowBackground" Value="{StaticResource ControlBrush}"/>
    <!-- Excel-like grid -->
    <Setter Property="GridLinesVisibility" Value="All"/>
    <Setter Property="HorizontalGridLinesBrush" Value="#FF2A3142"/>
    <Setter Property="VerticalGridLinesBrush" Value="#FF2A3142"/>
    <Setter Property="RowHeaderWidth" Value="0"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
    <Setter Property="SelectionUnit" Value="FullRow"/>
    <Setter Property="SelectionMode" Value="Single"/>
    <Setter Property="AutoGenerateColumns" Value="False"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
  </Style>

  <!-- Excel-like cells with readable padding and neon selection -->
  <Style TargetType="DataGridCell">
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="BorderBrush" Value="#FF2A3142"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#FF1D3320"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="DataGridRow">
    <Setter Property="MinHeight" Value="28"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#FF1D3320"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="Padding" Value="8,6"/>
  </Style>

  <Style TargetType="Menu">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
  </Style>

  <!-- Tabs: dark background + neon header text -->
  <Style TargetType="TabControl">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="Padding" Value="2"/>
  </Style>

  <Style TargetType="TabItem">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FF1E2432" Offset="0"/>
          <GradientStop Color="#FF141A26" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="Foreground" Value="{DynamicResource NeonBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="Margin" Value="2,0,2,0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6,6,0,0"
                  Padding="{TemplateBinding Padding}"
                  Margin="{TemplateBinding Margin}"
                  Effect="{StaticResource ControlShadow}">
            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource NeonBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="#FF4A4F5E"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>