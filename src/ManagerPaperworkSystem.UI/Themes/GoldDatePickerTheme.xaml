<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- COLOR PALETTE -->
    <Color x:Key="DpGold">#B87333</Color>
    <Color x:Key="DpGoldDim">#80B87333</Color>
    <Color x:Key="DpBg">#FF071827</Color>
    <Color x:Key="DpCard">#FF10243A</Color>
    <Color x:Key="DpPopup">#FF132C45</Color>
    <Color x:Key="DpBorder">#FF24445F</Color>
    <Color x:Key="DpText">#FFF4F1EA</Color>
    <Color x:Key="DpDim">#FF9BA8B5</Color>
    <Color x:Key="DpHover">#FF1E4B68</Color>
    <Color x:Key="DpSelected">#FFFFFFFF</Color>

    <SolidColorBrush x:Key="DpGoldBrush" Color="{StaticResource DpGold}"/>
    <SolidColorBrush x:Key="DpGoldDimBrush" Color="{StaticResource DpGoldDim}"/>
    <SolidColorBrush x:Key="DpBgBrush" Color="{StaticResource DpBg}"/>
    <SolidColorBrush x:Key="DpCardBrush" Color="{StaticResource DpCard}"/>
    <SolidColorBrush x:Key="DpPopupBrush" Color="{StaticResource DpPopup}"/>
    <SolidColorBrush x:Key="DpBorderBrush" Color="{StaticResource DpBorder}"/>
    <SolidColorBrush x:Key="DpTextBrush" Color="{StaticResource DpText}"/>
    <SolidColorBrush x:Key="DpDimBrush" Color="{StaticResource DpDim}"/>
    <SolidColorBrush x:Key="DpHoverBrush" Color="{StaticResource DpHover}"/>
    <SolidColorBrush x:Key="DpSelectedBrush" Color="{StaticResource DpSelected}"/>

    <!-- CALENDAR DAY BUTTON -->
    <Style x:Key="GoldCalendarDayButton" TargetType="CalendarDayButton">
        <Setter Property="Foreground" Value="{StaticResource DpGoldBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Grid>
                        <Ellipse x:Name="bg" Fill="Transparent" Width="34" Height="34"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse x:Name="todayRing" Width="34" Height="34" StrokeThickness="0"
                                 Stroke="Transparent"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="todayRing" Property="Stroke" Value="{StaticResource DpGoldBrush}"/>
                            <Setter TargetName="todayRing" Property="StrokeThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Fill" Value="{StaticResource DpHoverBrush}"/>
                        </Trigger>
                        <!-- SELECTED: WHITE circle, DARK text -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="Fill" Value="{StaticResource DpSelectedBrush}"/>
                <Setter Property="Foreground" Value="#FF071827"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DpDimBrush}"/>
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Opacity" Value="0.15"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CALENDAR MONTH/YEAR BUTTON -->
    <Style x:Key="GoldCalendarButton" TargetType="CalendarButton">
        <Setter Property="Foreground" Value="{StaticResource DpTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinWidth" Value="50"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Grid>
                        <Rectangle x:Name="bg" Fill="Transparent" RadiusX="6" RadiusY="6"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Fill" Value="{StaticResource DpHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="bg" Property="Fill" Value="{StaticResource DpGoldDimBrush}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CALENDAR -->
    <Style x:Key="GoldCalendar" TargetType="Calendar">
        <Setter Property="Foreground" Value="{StaticResource DpTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource DpPopupBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DpGoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource GoldCalendarDayButton}"/>
        <Setter Property="CalendarButtonStyle" Value="{StaticResource GoldCalendarButton}"/>
    </Style>

    <!-- DATEPICKER TEXTBOX (read-only, non-interactive — clicks pass through) -->
    <Style x:Key="GoldDatePickerTextBox" TargetType="DatePickerTextBox">
        <Setter Property="Foreground" Value="{StaticResource DpTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Padding" Value="4,6,4,4"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <Grid>
                        <Border Background="Transparent">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <TextBlock x:Name="watermark"
                                   Text="Select date..."
                                   Foreground="{StaticResource DpDimBrush}"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                            <Setter TargetName="watermark" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════
         GOLD DATEPICKER
         
         Key design: PART_Button spans the FULL width of the control
         as an invisible overlay. This means clicking ANYWHERE on
         the control triggers the native WPF dropdown toggle — no
         code-behind needed. The calendar icon is placed visually
         at the right edge using a separate non-interactive Path.
         
         Click once → opens. Select date → closes automatically.
         This is the stock WPF DatePicker behavior, just restyled.
         ══════════════════════════════════════════════════════════════ -->
    <Style x:Key="GoldDatePicker" TargetType="DatePicker">
        <Setter Property="Foreground" Value="{StaticResource DpTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="IsTodayHighlighted" Value="True"/>
        <Setter Property="SelectedDateFormat" Value="Short"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="MinWidth" Value="200"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="CalendarStyle" Value="{StaticResource GoldCalendar}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Border x:Name="rootBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0,0,0,2"
                            BorderBrush="{StaticResource DpBorderBrush}"
                            SnapsToDevicePixels="True"
                            Cursor="Hand">
                        <Grid>
                            <!-- Date text (non-interactive, just displays the date) -->
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Style="{StaticResource GoldDatePickerTextBox}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,0,32,0"/>

                            <!-- Calendar icon (visual only, not clickable — the button behind handles clicks) -->
                            <Path Width="18" Height="18"
                                  Stretch="Uniform"
                                  Fill="{StaticResource DpGoldBrush}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  IsHitTestVisible="False"
                                  Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z"/>

                            <!-- PART_Button: invisible, spans FULL width — 
                                 clicking anywhere triggers native dropdown toggle -->
                            <Button x:Name="PART_Button"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Opacity="0"/>

                            <!-- Popup calendar -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=rootBorder}"
                                   StaysOpen="False">
                                <Border Background="{StaticResource DpPopupBrush}"
                                        BorderBrush="{StaticResource DpGoldBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4"
                                        Margin="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="Black"/>
                                    </Border.Effect>
                                    <Calendar x:Name="PART_Calendar"
                                              Style="{StaticResource GoldCalendar}"
                                              Margin="4"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{StaticResource DpGoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{StaticResource DpGoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
