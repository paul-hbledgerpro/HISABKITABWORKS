<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- =====================
       HISAB KITAB
       ENHANCED Vibrant Theme
       Modern, Colorful, Professional
     ===================== -->

  <!-- Navy + Copper Palette -->
  <Color x:Key="BgColor">#FF071827</Color>
  <Color x:Key="PanelColor">#FF10243A</Color>
  <Color x:Key="ControlColor">#FF132C45</Color>
  <Color x:Key="BorderColor">#FF24445F</Color>
  <Color x:Key="TextColor">#FFF4F1EA</Color>
  <Color x:Key="MutedTextColor">#FF9BA8B5</Color>
  <Color x:Key="HintTextColor">#FF748495</Color>

  <!-- Vibrant Multi-Color Accents -->
  <Color x:Key="AccentColor">#FFB87333</Color>
  <Color x:Key="Accent2Color">#FFD49A5B</Color>
  <Color x:Key="Accent3Color">#FFF1C18C</Color>
  <Color x:Key="Accent4Color">#FF2FBF9B</Color>
  <Color x:Key="Accent5Color">#FFD65A5A</Color>
  <Color x:Key="AccentCyan">#FF4FB5D8</Color>

  <!-- Gradient Background -->
  <LinearGradientBrush x:Key="BgBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF071827" Offset="0"/>
    <GradientStop Color="#FF0B2033" Offset="0.55"/>
    <GradientStop Color="#FF06121E" Offset="1"/>
  </LinearGradientBrush>

  <!-- Shimmery / shiny black brush for tiles & cards -->
  <LinearGradientBrush x:Key="TileShimmerBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF0D2134" Offset="0"/>
    <GradientStop Color="#FF17324C" Offset="0.35"/>
    <GradientStop Color="#FF10243A" Offset="0.7"/>
    <GradientStop Color="#FF0A1B2B" Offset="1"/>
  </LinearGradientBrush>


  <!-- Solid Brushes -->
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="ControlBrush" Color="{StaticResource ControlColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="WhiteTextBrush" Color="#FFF4F1EA"/>
  <SolidColorBrush x:Key="TileValueBrush" Color="#FFF4F1EA"/>
  <SolidColorBrush x:Key="TileTitleBrush" Color="{StaticResource AccentColor}"/>

  <SolidColorBrush x:Key="ErrorBrush" Color="#FFD65A5A"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="#FF2FBF9B"/>
  <SolidColorBrush x:Key="WarningBrush" Color="#FFD49A5B"/>
  <SolidColorBrush x:Key="SidebarBrush" Color="#FF081A2A"/>
  <SolidColorBrush x:Key="SidebarNavBrush" Color="#0010243A"/>
  <SolidColorBrush x:Key="SidebarNavHoverBrush" Color="#331E4B68"/>
  <SolidColorBrush x:Key="SidebarNavActiveBrush" Color="#22D49A5B"/>

  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
  <SolidColorBrush x:Key="HintTextBrush" Color="{StaticResource HintTextColor}"/>

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2Color}"/>
  <SolidColorBrush x:Key="Accent3Brush" Color="{StaticResource Accent3Color}"/>
  <SolidColorBrush x:Key="Accent4Brush" Color="{StaticResource Accent4Color}"/>
  <SolidColorBrush x:Key="Accent5Brush" Color="{StaticResource Accent5Color}"/>

  <!-- Multi-Stop Accent Gradient for Headers/Buttons -->
  <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF071827" Offset="0"/>
    <GradientStop Color="#FFB87333" Offset="0.62"/>
    <GradientStop Color="#FF071827" Offset="1"/>
  </LinearGradientBrush>

  <!-- Primary Button Gradient (Lighter Gold for text visibility) -->
  <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFE9B77B" Offset="0"/>
    <GradientStop Color="#FFD49A5B" Offset="0.55"/>
    <GradientStop Color="#FFB87333" Offset="1"/>
  </LinearGradientBrush>

  <!-- Hover State -->
  <LinearGradientBrush x:Key="AccentButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFF1C18C" Offset="0"/>
    <GradientStop Color="#FFE0A363" Offset="0.55"/>
    <GradientStop Color="#FFC78342" Offset="1"/>
  </LinearGradientBrush>

  <!-- Pressed State -->
  <LinearGradientBrush x:Key="AccentButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF9F612D" Offset="0"/>
    <GradientStop Color="#FF7E431D" Offset="1"/>
  </LinearGradientBrush>

  <!-- Success Button (Green) -->
  <LinearGradientBrush x:Key="SuccessButtonBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF10B981" Offset="0"/>
    <GradientStop Color="#FF059669" Offset="1"/>
  </LinearGradientBrush>

  <!-- Warning Button (Amber) -->
  <LinearGradientBrush x:Key="WarningButtonBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFF59E0B" Offset="0"/>
    <GradientStop Color="#FFD97706" Offset="1"/>
  </LinearGradientBrush>

  <!-- Accent button text -->
  <!-- Gold buttons must use BLACK text for the HB black/gold brand -->
  <SolidColorBrush x:Key="AccentButtonTextBrush" Color="#FF071827"/>

  <!-- Enhanced Button fills with lighter gold for better text visibility -->
  <LinearGradientBrush x:Key="ButtonFill" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFE9B77B" Offset="0"/>
    <GradientStop Color="#FFD49A5B" Offset="0.55"/>
    <GradientStop Color="#FFB87333" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="ButtonFillHover" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFF1C18C" Offset="0"/>
    <GradientStop Color="#FFE9B77B" Offset="0.55"/>
    <GradientStop Color="#FFD49A5B" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="ButtonFillPressed" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFB87333" Offset="0"/>
    <GradientStop Color="#FF8D4F25" Offset="1"/>
  </LinearGradientBrush>

  <!-- Enhanced Shadows for depth -->
  <DropShadowEffect x:Key="ControlShadow" 
                    BlurRadius="20" 
                    ShadowDepth="3" 
                    Opacity="0.15"
                    Color="#FFB87333"/>
  
  <DropShadowEffect x:Key="TileShadow" 
                    BlurRadius="28" 
                    ShadowDepth="5" 
                    Opacity="0.18"
                    Color="#FFB87333"/>

  <DropShadowEffect x:Key="ButtonShadow"
                    BlurRadius="12"
                    ShadowDepth="3"
                    Opacity="0.25"
                    Color="#FFB87333"/>

  <!-- Card/Panel Shadow -->
  <DropShadowEffect x:Key="CardShadow"
                    BlurRadius="16"
                    ShadowDepth="4"
                    Opacity="0.12"
                    Color="#FF000000"/>

  <!-- =====================================================
       SYSTEM COLORS (critical for popup readability)
     ===================================================== -->
  <!-- Window/control backgrounds -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource ControlColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FFF7FAFE"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FFE6EFFA"/>

  <!-- Text -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FF000000"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF000000"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#FF555555"/>

  <!-- Selection -->
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF000000"/>

  <!-- MENU POPUPS (this fixes your invisible menus) -->
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FF102033"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#33B87333"/>
  <!-- NOTE: "MenuTextHighlightBrushKey" is not a valid WPF SystemColors key and crashes app startup.
       Menu highlighted text remains readable via the MenuItem style (Foreground = TextBrush).
       Remove the invalid key to prevent XAML parse failure. -->

  <!-- =====================================================
       BASE TYPOGRAPHY
     ===================================================== -->
  <Style TargetType="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <!-- =====================================================
       CARDS / PANELS
     ===================================================== -->
  <Style x:Key="CardStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource TileShimmerBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="18"/>
    <Setter Property="Padding" Value="16"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
</Style>

  <!-- =====================================================
       INPUTS
     ===================================================== -->
  <Style TargetType="TextBox">
    <Setter Property="MinHeight" Value="40"/>
    <Setter Property="MinWidth" Value="170"/>
    <Setter Property="Background" Value="#FFFFFFFF"/>
    <!-- Inputs must be BLACK text -->
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="SelectionTextBrush" Value="#FFFFFFFF"/>
    <Style.Triggers>
      <Trigger Property="IsKeyboardFocusWithin" Value="True">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="PasswordBox">
    <Setter Property="MinHeight" Value="40"/>
    <Setter Property="Background" Value="#FFFFFFFF"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="MinHeight" Value="38"/>
    <Setter Property="Background" Value="#FFFFFFFF"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="TextElement.Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid SnapsToDevicePixels="True">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"/>

            <DockPanel Margin="1">
              <ToggleButton x:Name="Toggle"
                            DockPanel.Dock="Right"
                            Focusable="False"
                            Width="32"
                            Background="Transparent"
                            BorderThickness="0"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <Path Data="M 0 0 L 5 5 L 10 0 Z"
                      Fill="{StaticResource AccentBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
              </ToggleButton>

              <ContentPresenter x:Name="ContentSite"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                <ContentPresenter.Resources>
                  <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#FF000000"/>
                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                  </Style>
                </ContentPresenter.Resources>
              </ContentPresenter>

              <TextBox x:Name="PART_EditableTextBox"
                       Margin="{TemplateBinding Padding}"
                       Background="Transparent"
                       Foreground="{TemplateBinding Foreground}"
                       CaretBrush="{StaticResource AccentBrush}"
                       BorderThickness="0"
                       Visibility="Hidden"
                       IsReadOnly="{TemplateBinding IsReadOnly}"/>
            </DockPanel>

            <Popup x:Name="Popup"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   Focusable="False"
                   PopupAnimation="Fade">
              <Border Background="#FFFFFFFF"
                      BorderBrush="{StaticResource AccentBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                <ScrollViewer Margin="0"
                              SnapsToDevicePixels="True"
                              CanContentScroll="True">
                  <ItemsPresenter/>
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
              <Setter TargetName="ContentSite" Property="Opacity" Value="0.75"/>
            </Trigger>
            <Trigger Property="IsEditable" Value="True">
              <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
              <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsKeyboardFocusWithin" Value="True">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ComboBoxItem">
    <!-- Dropdown items must be BLACK text on a WHITE background -->
    <Style.Resources>
      <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FF000000"/>
      </Style>
      <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="Background" Value="#FFFFFFFF"/>
      </Style>
    </Style.Resources>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="TextElement.Foreground" Value="#FF000000"/>
    <Setter Property="Background" Value="#FFFFFFFF"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="Transparent"
                  BorderThickness="0"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True"
                              TextElement.Foreground="{TemplateBinding Foreground}">
              <ContentPresenter.Resources>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="#FF000000"/>
                  <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                </Style>
              </ContentPresenter.Resources>
            </ContentPresenter>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#FFEFE6C8"/>
              <Setter Property="Foreground" Value="#FF000000"/>
              <Setter Property="TextElement.Foreground" Value="#FF000000"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#FFE7DCB8"/>
              <Setter Property="Foreground" Value="#FF000000"/>
              <Setter Property="TextElement.Foreground" Value="#FF000000"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="#FFEFE6C8"/>
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="TextElement.Foreground" Value="#FF000000"/>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#FFE7DCB8"/>
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="TextElement.Foreground" Value="#FF000000"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Using Windows default DatePicker and Calendar - NO custom styling -->

  <!-- =====================================================
       BUTTONS (3D / modern) - Lighter Gold with Black Text
     ===================================================== -->
  <Style TargetType="Button">
    <Setter Property="MinHeight" Value="40"/>
    <Setter Property="MinWidth" Value="170"/>
    <Setter Property="Padding" Value="16,10"/>
    <Setter Property="Margin" Value="0,8,0,0"/>
    <Setter Property="Background" Value="{StaticResource ButtonFill}"/>
    <!-- Buttons: lighter gold with black text -->
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="#FFB87333"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <!-- Subtle cast shadow layer (helps the 3D feel even without effects) -->
            <Border x:Name="Cast"
                    CornerRadius="14"
                    Background="#1A000000"
                    Margin="0,3,0,0"
                    Opacity="0.22"/>

            <Border x:Name="Bd"
                    CornerRadius="14"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#FFE9B77B" Offset="0"/>
                  <GradientStop Color="#FFD49A5B" Offset="0.55"/>
                  <GradientStop Color="#FFB87333" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <TranslateTransform Y="0"/>
              </Border.RenderTransform>
              <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.16"/>
              </Border.Effect>

              <Grid>
                <!-- Gloss highlight -->
                <Border x:Name="Gloss" CornerRadius="14" Margin="1" Opacity="0.28" IsHitTestVisible="False">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFFFFFFF" Offset="0"/>
                      <GradientStop Color="#55FFFFFF" Offset="0.28"/>
                      <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>

                <!--
                  SHIMMER SAFETY LAYERS
                  ====================
                  Some builds/styles reference a storyboard TargetName "ShimmerX".
                  If the target name does not exist inside the template name-scope,
                  WPF throws and the app can close immediately after login.

                  To permanently prevent that startup crash, we provide BOTH names
                  (ShimmerX and Shimmer) inside the default Button template.
                -->
                <Rectangle x:Name="ShimmerX" IsHitTestVisible="False" Opacity="0" RadiusX="14" RadiusY="14">
                  <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                      <GradientStop Color="#00FFFFFF" Offset="0"/>
                      <GradientStop Color="#33FFFFFF" Offset="0.5"/>
                      <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                  </Rectangle.Fill>
                </Rectangle>
                <Rectangle x:Name="Shimmer" IsHitTestVisible="False" Opacity="0" RadiusX="14" RadiusY="14">
                  <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                      <GradientStop Color="#00FFFFFF" Offset="0"/>
                      <GradientStop Color="#33FFFFFF" Offset="0.5"/>
                      <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                  </Rectangle.Fill>
                </Rectangle>

                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                  <ContentPresenter.Resources>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="#FF000000"/>
                      <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                  </ContentPresenter.Resources>
                </ContentPresenter>
              </Grid>
            </Border>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="#FFB87333"/>
              <Setter TargetName="Bd" Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFF1C18C" Offset="0"/>
                    <GradientStop Color="#FFE9B77B" Offset="0.55"/>
                    <GradientStop Color="#FFD49A5B" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Bd" Property="Effect">
                <Setter.Value>
                  <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.20"/>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Cast" Property="Opacity" Value="0.26"/>
              <Setter TargetName="Bd" Property="RenderTransform">
                <Setter.Value>
                  <TranslateTransform Y="-1"/>
                </Setter.Value>
              </Setter>
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFB87333" Offset="0"/>
                    <GradientStop Color="#FF8D4F25" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Bd" Property="RenderTransform">
                <Setter.Value>
                  <TranslateTransform Y="1"/>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Cast" Property="Margin" Value="0,1,0,0"/>
              <Setter TargetName="Bd" Property="Effect">
                <Setter.Value>
                  <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.12"/>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Gloss" Property="Opacity" Value="0.18"/>
            </Trigger>

            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>


  <!-- Primary button helper style -->
  <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Background" Value="{DynamicResource AccentButtonBrush}"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

    <!-- Secondary button style - Same gold 3D style with black text -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource AccentButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#FF000000" />
    </Style>


  
  <!-- Icon button helper style -->
  <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="MinWidth" Value="42"/>
    <Setter Property="MinHeight" Value="42"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0"/>
  </Style>

<!-- Dashboard tiles -->
  <Style x:Key="TileButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="MinHeight" Value="96"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Tile"
                  Background="{StaticResource TileShimmerBrush}"
                  BorderBrush="{StaticResource AccentBrush}"
                  BorderThickness="1"
                  CornerRadius="18"
                  Padding="16"
                  Effect="{StaticResource TileShadow}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" CornerRadius="14" Background="{StaticResource AccentGradient}" Padding="10">
                <ContentPresenter x:Name="IconPresenter" Content="{TemplateBinding Tag}"/>
              </Border>

              <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <ContentPresenter x:Name="TitlePresenter" Content="{TemplateBinding Content}"/>
                <TextBlock x:Name="Sub" Text="" Foreground="{StaticResource HintTextBrush}" Margin="0,6,0,0"/>
              </StackPanel>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource Accent3Brush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Tile" Property="Opacity" Value="0.96"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>



  <!-- =====================================================
       NAV BUTTONS (Dashboard shortcuts) - Navy + Copper
     ===================================================== -->
  <Style x:Key="NavButton" TargetType="Button">
    <Setter Property="MinHeight" Value="46"/>
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <!-- Shadow layer for 3D effect -->
            <Border x:Name="Shadow" CornerRadius="14" Background="#1A000000" Margin="0,3,0,0" Opacity="0.25"/>
            
            <Border x:Name="Bd" CornerRadius="14" BorderThickness="1" BorderBrush="#FFB87333">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#FFE9B77B" Offset="0"/>
                  <GradientStop Color="#FFD49A5B" Offset="0.55"/>
                  <GradientStop Color="#FFB87333" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <TranslateTransform x:Name="BdTransform" Y="0"/>
              </Border.RenderTransform>
              <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.18" Color="#FFB87333"/>
              </Border.Effect>
              
              <Grid Margin="{TemplateBinding Padding}">
                <!-- Gloss highlight -->
                <Border x:Name="Gloss" CornerRadius="12" Margin="-14,-10" Opacity="0.3" IsHitTestVisible="False">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#FFFFFFFF" Offset="0"/>
                      <GradientStop Color="#55FFFFFF" Offset="0.28"/>
                      <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
                
                <!-- Shimmer effect -->
                <Rectangle x:Name="ShimmerX" IsHitTestVisible="False" Opacity="0" RadiusX="12" RadiusY="12" Margin="-14,-10">
                  <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                      <GradientStop Color="#00FFFFFF" Offset="0"/>
                      <GradientStop Color="#44FFFFFF" Offset="0.5"/>
                      <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                  </Rectangle.Fill>
                </Rectangle>
                
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <ContentPresenter Grid.Column="0" Content="{TemplateBinding Tag}" VerticalAlignment="Center" HorizontalAlignment="Center" TextElement.Foreground="#FF000000"/>
                  <ContentPresenter Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextElement.Foreground="#FF000000"/>
                </Grid>
              </Grid>
            </Border>
          </Grid>
          
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFF1C18C" Offset="0"/>
                    <GradientStop Color="#FFE9B77B" Offset="0.55"/>
                    <GradientStop Color="#FFD49A5B" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Shadow" Property="Opacity" Value="0.30"/>
              <Setter TargetName="ShimmerX" Property="Opacity" Value="0.4"/>
              <Setter TargetName="Bd" Property="Effect">
                <Setter.Value>
                  <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.22" Color="#FFB87333"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFB87333" Offset="0"/>
                    <GradientStop Color="#FF8D4F25" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Shadow" Property="Margin" Value="0,1,0,0"/>
              <Setter TargetName="Gloss" Property="Opacity" Value="0.18"/>
              <Setter TargetName="Bd" Property="Effect">
                <Setter.Value>
                  <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.14" Color="#FFB87333"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SidebarNavButton" TargetType="Button">
    <Setter Property="MinHeight" Value="38"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Margin" Value="0,2,0,2"/>
    <Setter Property="Background" Value="{StaticResource SidebarNavBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="AccentRail" Background="Transparent" CornerRadius="2"/>
              <ContentPresenter Grid.Column="2"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarNavHoverBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="#445F7C"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="AccentRail" Property="Background" Value="{StaticResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Compact stat cards used on Dashboard -->
  <Style x:Key="StatCard" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource TileShimmerBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="18"/>
    <Setter Property="Padding" Value="16"/>
    <Setter Property="Effect" Value="{StaticResource TileShadow}"/>
</Style>

  <!-- =====================================================
       MENUS - Black background with shimmery gold buttons
     ===================================================== -->
  <Style TargetType="Menu">
    <Setter Property="Background" Value="#FF0B0B0F"/>
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
  </Style>

  <Style TargetType="ContextMenu">
    <Setter Property="Background" Value="#FFFFFFFF"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="Margin" Value="2"/>
    <Style.Triggers>
      <Trigger Property="Role" Value="TopLevelHeader">
        <Setter Property="Foreground" Value="{StaticResource Accent3Brush}"/>
      </Trigger>
      <Trigger Property="Role" Value="TopLevelItem">
        <Setter Property="Foreground" Value="{StaticResource Accent3Brush}"/>
      </Trigger>
      <Trigger Property="Role" Value="SubmenuHeader">
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="Background" Value="#FFFFFFFF"/>
      </Trigger>
      <Trigger Property="Role" Value="SubmenuItem">
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="Background" Value="#FFFFFFFF"/>
      </Trigger>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="#33B87333"/>
        <Setter Property="Foreground" Value="#FF000000"/>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.45"/>
      </Trigger>
    </Style.Triggers>
  </Style>



  <!-- =====================================================
       DATA GRID (HB Navy/Copper)
     ===================================================== -->
  <Style TargetType="DataGrid">
    <Setter Property="Background" Value="{StaticResource TileShimmerBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="RowBackground" Value="#FF0B0B0F"/>
    <Setter Property="AlternatingRowBackground" Value="#FF111116"/>
    <Setter Property="GridLinesVisibility" Value="None"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
    <Setter Property="RowHeaderWidth" Value="0"/>
    <Setter Property="CanUserAddRows" Value="False"/>
    <Setter Property="CanUserDeleteRows" Value="False"/>
    <Setter Property="CanUserResizeRows" Value="False"/>
    <Setter Property="ColumnHeaderHeight" Value="42"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="SelectionUnit" Value="FullRow"/>
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="#FFD49A5B"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="#FFB87333"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Padding" Value="10,10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DataGridColumnHeader">
          <Border Background="{TemplateBinding Background}" 
                  BorderBrush="{TemplateBinding BorderBrush}" 
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center">
              <ContentPresenter.Resources>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="#FF000000"/>
                  <Setter Property="FontWeight" Value="Bold"/>
                </Style>
              </ContentPresenter.Resources>
            </ContentPresenter>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="DataGridRow">
    <Setter Property="MinHeight" Value="36"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#FF1A1A22"/>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#33B87333"/>
        <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="DataGridCell">
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="10,6"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentButtonTextBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Input field background + text: WHITE background with GOLD border and BLACK fonts -->
  <SolidColorBrush x:Key="FieldBrush" Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="FieldTextBrush" Color="#FF000000"/>

  <!-- Hide Tab headers (dashboard-only navigation) -->
  <Style x:Key="HiddenTabItem" TargetType="TabItem">
    <Setter Property="Visibility" Value="Collapsed"/>
  </Style>

</ResourceDictionary>
