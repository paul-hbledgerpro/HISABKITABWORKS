<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- Modern, readable dark theme.
       Key goal: ensure ALL popups (ComboBox/Menu/DatePicker calendar) are readable on dark backgrounds.
       This file intentionally overrides SystemColors keys used by default WPF control templates. -->

  <!-- Palette -->
  <Color x:Key="BgColor">#FF0B1220</Color>
  <Color x:Key="PanelColor">#FF0F172A</Color>
  <Color x:Key="ControlColor">#FF111C33</Color>
  <Color x:Key="BorderColor">#FF24324A</Color>
  <Color x:Key="TextColor">#FFEAF0FF</Color>
  <Color x:Key="MutedTextColor">#FFBFD6FF</Color>
  <Color x:Key="HintTextColor">#FF93A4C7</Color>

  <!-- Accent -->
  <Color x:Key="AccentColor">#FF38BDF8</Color>
  <Color x:Key="NeonColor">#FF38BDF8</Color>

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="NeonBrush" Color="{StaticResource NeonColor}"/>

  <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF58CCFF" Offset="0"/>
    <GradientStop Color="#FF1DA6E5" Offset="1"/>
  </LinearGradientBrush>

  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="ControlBrush" Color="{StaticResource ControlColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
  <SolidColorBrush x:Key="HintTextBrush" Color="{StaticResource HintTextColor}"/>

  <!-- Default WPF templates use SystemColors.* keys for popup elements.
       These overrides fix "black on dark" / "dark on dark" issues. -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF0F172A"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF111C33"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF14203A"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FF0A1224"/>

  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource HintTextColor}"/>

  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF071018"/>

  <!-- Softer shadow -->
  <DropShadowEffect x:Key="ControlShadow" BlurRadius="18" ShadowDepth="2" Opacity="0.28"/>

  <!-- Typography -->
  <Style TargetType="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <!-- Cards -->
  <Style TargetType="Border">
    <Setter Property="CornerRadius" Value="14"/>
  </Style>

  <!-- Inputs -->
  <Style TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="SelectionTextBrush" Value="#FF071018"/>
  </Style>

  <Style TargetType="PasswordBox">
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="#FF14203A"/>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#33238BE6"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.55"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- DatePicker & Calendar (fix unreadable calendar text) -->
  <Style TargetType="DatePicker">
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
  </Style>

  <Style TargetType="DatePickerTextBox">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="6,2"/>
    <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style TargetType="Calendar">
    <Setter Property="Background" Value="#FF0F172A"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style TargetType="CalendarDayButton">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#FF14203A"/>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FF071018"/>
      </Trigger>
      <Trigger Property="IsToday" Value="True">
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      </Trigger>
      <Trigger Property="IsInactive" Value="True">
        <Setter Property="Opacity" Value="0.45"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="CalendarButton">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#FF14203A"/>
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Background" Value="#FF0A1224"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="CalendarItem">
    <Setter Property="Background" Value="#FF0F172A"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <!-- Buttons: clean modern -->
  <Style TargetType="Button">
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="Margin" Value="0,6,0,0"/>
    <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="12"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="Bd" Property="Background" Value="#FF14203A"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
              <Setter TargetName="Bd" Property="RenderTransform">
                <Setter.Value>
                  <TranslateTransform Y="1"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- DataGrid: modern (no Excel gridlines) -->
  <Style TargetType="DataGrid">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="GridLinesVisibility" Value="None"/>
    <Setter Property="RowHeaderWidth" Value="0"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
    <Setter Property="RowBackground" Value="{StaticResource PanelBrush}"/>
    <Setter Property="AlternatingRowBackground" Value="#FF0D1A31"/>
    <Setter Property="SelectionUnit" Value="FullRow"/>
    <Setter Property="SelectionMode" Value="Single"/>
    <Setter Property="Effect" Value="{StaticResource ControlShadow}"/>
  </Style>

  <Style TargetType="DataGridRow">
    <Setter Property="MinHeight" Value="34"/>
  </Style>

  <Style TargetType="DataGridCell">
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#33238BE6"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="#FF0D1A31"/>
    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="Padding" Value="10,10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <!-- Tabs: pill-like modern -->
  <Style TargetType="TabControl">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style TargetType="TabItem">
    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
    <Setter Property="Background" Value="#00000000"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="Margin" Value="2,0,2,0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#FF14203A"/>
              <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
              <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#FF101A2E"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Menus / Popups -->
  <Style TargetType="Menu">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
  </Style>

  <Style TargetType="ContextMenu">
    <Setter Property="Background" Value="#FFFFFFFF"/>
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="#FF000000"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Margin" Value="2"/>
    <Style.Triggers>
      <Trigger Property="Role" Value="TopLevelHeader">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      </Trigger>
      <Trigger Property="Role" Value="TopLevelItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      </Trigger>
      <Trigger Property="Role" Value="SubmenuHeader">
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="Background" Value="#FFFFFFFF"/>
      </Trigger>
      <Trigger Property="Role" Value="SubmenuItem">
        <Setter Property="Foreground" Value="#FF000000"/>
        <Setter Property="Background" Value="#FFFFFFFF"/>
      </Trigger>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="#FFC7EAF8"/>
        <Setter Property="Foreground" Value="#FF000000"/>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.45"/>
      </Trigger>
    </Style.Triggers>
  </Style>

</ResourceDictionary>
